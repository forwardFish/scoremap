+module.exports = {
+  LocalJsonDbAdapter,
+  LocalTencentCloudMockAdapter,
+  LocalWechatPayMockAdapter,
+  createLocalAdapters
+};
diff --git a/server/src/adapters/local-tencent-cloud-mock.js b/server/src/adapters/local-tencent-cloud-mock.js
