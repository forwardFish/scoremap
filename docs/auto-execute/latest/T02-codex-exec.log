index 0000000000000000000000000000000000000000..137519e8edca1e02292a17d609ba032bd45ab998
--- /dev/null
+++ b/server/test/run-tests.js
@@ -0,0 +1,20 @@
+const { spawnSync } = require('node:child_process');
+const path = require('node:path');
+
+const args = [
