+  "knownGaps": [
+    {
+      "status": "DEFERRED",
+      "ownerTask": "T03",
+      "summary": "Order/upload/preview HTTP APIs are not in T02 scope."
+    },
+    {
+      "status": "DEFERRED",
+      "ownerTask": "T04",
+      "summary": "Payment HTTP routes and entitlement API flow are not in T02 scope."
+    },
+    {
+      "status": "DEFERRED",
+      "ownerTask": "T14",
+      "summary": "Visual screenshot/diff evidence is not in T02 scope."
+    },
+    {
+      "status": "DEFERRED",
+      "ownerTask": "T15",
+      "summary": "Full parent owner journey click traces are not in T02 scope."
+    }
+  ]
+}
