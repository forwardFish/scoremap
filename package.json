{
  "name": "scoremap-local-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Local-only scaffold for scoremap miniapp, API, and mock persistence.",
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "e2e:owner": "node --test tests/e2e/owner-click-flow.test.js",
    "e2e:api-db": "node --test --test-concurrency=1 tests/api/api-db-readback-e2e.test.js",
    "visual:scoremap": "node tools/ui-visual/run-scoremap-visual.mjs",
    "visual:replica": "node tools/ui-visual/annotate-scoremap-replica.mjs",
    "acceptance:real-llm-upload": "node scripts/acceptance/run-real-llm-student-upload.mjs && node scripts/acceptance/verify-real-llm-student-upload-report.mjs",
    "build": "node scripts/build-local-runtime.mjs",
    "start:api": "node server/src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "@cloudbase/node-sdk": "^3.18.3",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.16.0",
    "uuid": "^14.0.0"
  }
}
