page { min-height: 100%; background: #f8f8ff; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; text-align: left; }
button::after { border: 0; }

.feedback-screen {
  min-height: 100vh;
  padding: 64rpx 30rpx 164rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e6e6fa 0%, #f8f8ff 25%, #f8f8ff 100%);
  color: #111827;
}
.feedback-header { margin-bottom: 28rpx; }
.feedback-header-icon { width: 76rpx; height: 76rpx; display: block; object-fit: contain; margin-bottom: 18rpx; }
.feedback-title { display: block; font-size: 42rpx; line-height: 1.15; font-weight: 900; }
.feedback-subtitle { display: block; margin-top: 14rpx; font-size: 24rpx; line-height: 1.5; color: #6b7280; }
.feedback-card { margin-bottom: 22rpx; padding: 28rpx; border-radius: 32rpx; background: #fff; box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.05); box-sizing: border-box; }
.section-label { display: flex; align-items: center; gap: 10rpx; margin-bottom: 20rpx; font-size: 26rpx; font-weight: 900; color: #111827; }
.section-icon { width: 32rpx; height: 32rpx; display: block; object-fit: contain; }
.rating-row, .tag-row { display: flex; flex-wrap: wrap; gap: 14rpx; }
.rating-chip, .tag { min-height: 48rpx; padding: 0 20rpx; border-radius: 999rpx; background: #f3f4f6; color: #6b7280; display: flex; align-items: center; font-size: 23rpx; font-weight: 800; }
.rating-chip.active { background: #111827; color: #fff; }
.tag.active { background: #ecfdf5; color: #047857; }
.feedback-textarea { min-height: 166rpx; padding: 24rpx; border-radius: 24rpx; background: #f8fafc; border: 2rpx solid #eef2f7; box-sizing: border-box; color: #374151; font-size: 26rpx; line-height: 1.55; }
.feedback-note { display: block; margin-top: 18rpx; font-size: 22rpx; line-height: 1.45; color: #9ca3af; }
.feedback-submit { position: fixed; left: 30rpx; right: 30rpx; bottom: 46rpx; height: 92rpx; border-radius: 30rpx; background: #111827; color: #fff; font-size: 30rpx; font-weight: 900; display: flex; align-items: center; justify-content: center; text-align: center; box-shadow: 0 18rpx 34rpx rgba(17, 24, 39, 0.18); }
