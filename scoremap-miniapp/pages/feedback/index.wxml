<view class="feedback-screen">
  <view class="feedback-header">
    <image class="feedback-header-icon" src="/assets/icons/chat-bubble.png" mode="aspectFit" />
    <text class="feedback-title">Help and feedback</text>
    <text class="feedback-subtitle">Submit local report feedback and return to My. No production service is called.</text>
  </view>

  <view class="feedback-card">
    <view class="section-label">
      <image class="section-icon" src="/assets/icons/success-check-green.png" mode="aspectFit" />
      <text>Report experience</text>
    </view>
    <view class="rating-row">
      <text class="rating-chip active">Helpful</text>
      <text class="rating-chip">Unclear</text>
      <text class="rating-chip">Inaccurate</text>
    </view>
  </view>

  <view class="feedback-card">
    <view class="section-label">
      <image class="section-icon" src="/assets/clean-icons/document-list-purple.png" mode="aspectFit" />
      <text>Feedback tags</text>
    </view>
    <view class="tag-row">
      <text class="tag active">Clear decision</text>
      <text class="tag active">Next step is clear</text>
      <text class="tag">Need more explanation</text>
    </view>
  </view>

  <view class="feedback-card">
    <view class="section-label">
      <image class="section-icon" src="/assets/icons/idea-bulb-soft.png" mode="aspectFit" />
      <text>Extra note</text>
    </view>
    <view class="feedback-textarea">
      <text>Local feedback: keep the next practice recommendation clear after the report is unlocked.</text>
    </view>
    <text class="feedback-note">The submit action writes to local mock storage for evidence only.</text>
  </view>

  <button class="feedback-submit" data-action="my" bindtap="onTap">Submit and return</button>
</view>
