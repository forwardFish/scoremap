@import "../ai-tutor/c13-common.wxss";

.feedback-page .content-scroll {
  height: 755px;
}

.result-card,
.analysis-card,
.record-row {
  margin: 10px 16px 0;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 6px 18px rgba(82, 69, 135, 0.06);
}

.result-card {
  padding: 25px 32px 20px;
  text-align: center;
}

.success-badge {
  width: 53px;
  height: 32px;
  margin: 0 auto;
  border-radius: 18px;
  background: #078a4b;
  color: #ffffff;
  font-size: 25px;
  line-height: 32px;
  font-weight: 900;
}

.success-title {
  display: block;
  margin-top: 11px;
  color: #079551;
  font-size: 25px;
  line-height: 34px;
  font-weight: 900;
}

.coach-row {
  margin-top: 16px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.coach {
  width: 48px;
  height: 48px;
  border-radius: 24px;
}

.coach-bubble {
  flex: 1;
  padding: 15px 17px;
  border-radius: 8px;
  background: #ded2ff;
  color: #6044dc;
  text-align: left;
  font-size: 14px;
  line-height: 22px;
  font-weight: 700;
}

.analysis-card {
  padding: 17px 24px 16px;
}

.section-title {
  color: #1e2439;
  font-size: 15px;
  font-weight: 900;
  border-left: 4px solid #6b4ee6;
  padding-left: 9px;
}

.formula-box {
  margin-top: 15px;
  padding: 13px 17px;
  border-left: 4px solid #6b4ee6;
  border-radius: 7px;
  background: #f2edf8;
  color: #30364e;
  font-size: 13px;
  line-height: 22px;
  display: flex;
  flex-direction: column;
}

.formula {
  color: #6b4ee6;
  font-size: 18px;
  font-weight: 900;
}

.answer-line {
  margin-top: 15px;
  color: #1e2439;
  font-size: 14px;
  font-weight: 900;
}

.answer-line text {
  padding: 1px 11px;
  border-radius: 6px;
  background: #eee7ff;
  color: #6b4ee6;
}

.tip {
  margin: 14px 16px 0;
  min-height: 46px;
  padding: 10px 18px;
  border-radius: 8px;
  background: #ece8f3;
  color: #3e4354;
  font-size: 13px;
  line-height: 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  box-sizing: border-box;
}

.tip.good {
  background: #e7f4ef;
  color: #098a4e;
}

.tip image {
  width: 24px;
  height: 24px;
}

.feedback-actions {
  margin: 18px 16px 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.retry-button,
.report-button {
  height: 36px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.retry-button {
  color: #6b4ee6;
  border: 1px solid #6b4ee6;
}

.report-button {
  color: #ffffff;
  background: #5d3fc9;
}

.record-row {
  height: 58px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  color: #1e2439;
  font-size: 13px;
  font-weight: 900;
}

.record-icon {
  width: 38px;
  height: 30px;
  margin-right: 10px;
  border-radius: 8px;
  background: #eee7fb;
  color: #6b4ee6;
  text-align: center;
  line-height: 30px;
}

.record-sub {
  display: block;
  margin-top: 2px;
  color: #4f586b;
  font-size: 11px;
  font-weight: 600;
}
