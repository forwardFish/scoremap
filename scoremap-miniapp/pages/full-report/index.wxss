page {
  min-height: 100%;
  background: #f6f7fb;
  color: #1f2430;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.full-report-page {
  position: relative;
  min-height: 100vh;
  background: #f6f7fb;
  padding-bottom: 112px;
}

body[data-screen="full-report"] .full-report-page,
body[data-screen="v13-full-report"] .full-report-page {
  width: 390px;
  height: 844px;
  min-height: 844px;
  padding: 0;
  overflow: hidden;
  background: #ffffff;
}

body[data-screen="full-report"] .page-scroll,
body[data-screen="full-report"] .repair-drawer,
body[data-screen="full-report"] .bottom-actions,
body[data-screen="full-report"] .toast,
body[data-screen="v13-full-report"] .page-scroll,
body[data-screen="v13-full-report"] .repair-drawer,
body[data-screen="v13-full-report"] .bottom-actions,
body[data-screen="v13-full-report"] .toast {
  display: none;
}

body[data-screen="full-report"] .page-scroll,
body[data-screen="v13-full-report"] .page-scroll {
  display: block;
}

body[data-screen="full-report"] .c10-status,
body[data-screen="v13-full-report"] .c10-status {
  visibility: hidden;
}

body[data-screen="full-report"] .bottom-actions,
body[data-screen="v13-full-report"] .bottom-actions {
  display: none;
}

.page-scroll {
  padding: 18px 18px 0;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
}

.page-title {
  font-size: 18px;
  font-weight: 700;
  color: #1f2430;
}

.icon-button {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  background: #ffffff;
  box-shadow: 0 8px 20px rgba(31, 36, 48, 0.08);
  text-align: center;
  line-height: 36px;
  font-size: 22px;
}

.share-icon {
  font-size: 17px;
}

.hero-card {
  margin-top: 18px;
  padding: 22px;
  border-radius: 24px;
  background: linear-gradient(135deg, #4533b7 0%, #7657db 54%, #f08b55 100%);
  color: #ffffff;
  box-shadow: 0 18px 36px rgba(69, 51, 183, 0.24);
}

.hero-copy {
  display: flex;
  flex-direction: column;
}

.hero-kicker {
  width: max-content;
  max-width: 100%;
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.18);
  font-size: 12px;
  font-weight: 700;
}

.hero-title {
  margin-top: 14px;
  font-size: 26px;
  line-height: 34px;
  font-weight: 800;
}

.hero-summary {
  margin-top: 10px;
  font-size: 14px;
  line-height: 22px;
  opacity: 0.9;
}

.quota-pill {
  margin-top: 16px;
  padding: 10px 12px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.18);
  font-size: 13px;
  font-weight: 700;
}

.value-section,
.wrong-section {
  margin-top: 24px;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  line-height: 24px;
  font-weight: 800;
}

.section-subtitle {
  max-width: 180px;
  text-align: right;
  font-size: 12px;
  line-height: 18px;
  color: #6f7583;
}

.value-card {
  margin-bottom: 12px;
  padding: 16px;
  border-radius: 20px;
  background: #ffffff;
  box-shadow: 0 10px 26px rgba(31, 36, 48, 0.07);
  border: 1px solid #eceff5;
}

.value-card-head {
  display: flex;
  align-items: center;
  gap: 12px;
}

.value-icon {
  width: 36px;
  height: 36px;
  flex: 0 0 36px;
}

.value-title-wrap {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.value-eyebrow {
  font-size: 11px;
  line-height: 16px;
  color: #7a8291;
}

.value-title {
  font-size: 16px;
  line-height: 22px;
  font-weight: 800;
  color: #1f2430;
}

.value-index {
  font-size: 12px;
  color: #a1a8b6;
}

.value-main {
  display: block;
  margin-top: 12px;
  font-size: 22px;
  line-height: 28px;
  font-weight: 800;
  color: #4533b7;
}

.value-content {
  display: block;
  margin-top: 8px;
  font-size: 13px;
  line-height: 21px;
  color: #555d6c;
}

.tone-score .value-main {
  color: #e5662c;
}

.tone-evidence .value-main {
  color: #2563eb;
}

.tone-priority .value-main {
  color: #0f8a4b;
}

.question-card {
  position: relative;
  margin-bottom: 12px;
  padding: 16px 16px 14px 22px;
  border-radius: 20px;
  background: #ffffff;
  box-shadow: 0 10px 26px rgba(31, 36, 48, 0.07);
  overflow: hidden;
}

.severity-line {
  position: absolute;
  left: 0;
  top: 0;
  width: 5px;
  height: 100%;
  background: #7657db;
}

.severity-line.high {
  background: #f08b55;
}

.question-title {
  display: block;
  font-size: 15px;
  line-height: 22px;
  font-weight: 800;
}

.question-stem {
  display: block;
  margin-top: 8px;
  font-size: 13px;
  line-height: 20px;
  color: #555d6c;
}

.question-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.question-meta text {
  padding: 4px 8px;
  border-radius: 999px;
  background: #f1f3f8;
  color: #596174;
  font-size: 11px;
}

.question-actions {
  display: flex;
  gap: 10px;
  margin-top: 14px;
}

.secondary-action,
.primary-action {
  flex: 1;
  height: 38px;
  border-radius: 14px;
  font-size: 13px;
  font-weight: 800;
  text-align: center;
  line-height: 38px;
}

.secondary-action {
  background: #f3f1ff;
  color: #4533b7;
}

.primary-action {
  background: #4533b7;
  color: #ffffff;
}

.notice-card {
  margin: 18px 0 8px;
  padding: 14px;
  border-radius: 16px;
  background: #fff8ed;
  color: #7a4b10;
  font-size: 12px;
  line-height: 20px;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 12px;
  padding: 14px 18px calc(14px + env(safe-area-inset-bottom));
  background: rgba(246, 247, 251, 0.94);
  box-shadow: 0 -10px 26px rgba(31, 36, 48, 0.08);
}

.outline-button,
.solid-button {
  flex: 1;
  height: 48px;
  border-radius: 16px;
  font-size: 15px;
  font-weight: 800;
  text-align: center;
  line-height: 48px;
}

.outline-button {
  background: #ffffff;
  color: #4533b7;
  border: 1px solid #d7d1ff;
}

.solid-button {
  background: #4533b7;
  color: #ffffff;
}

.toast {
  position: fixed;
  left: 50%;
  bottom: 92px;
  transform: translateX(-50%);
  max-width: 300px;
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(31, 36, 48, 0.9);
  color: #ffffff;
  font-size: 12px;
  text-align: center;
}

.repair-drawer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(31, 36, 48, 0.34);
}

.drawer-panel {
  width: 100%;
  padding: 18px 18px calc(18px + env(safe-area-inset-bottom));
  border-radius: 22px 22px 0 0;
  background: #ffffff;
  box-shadow: 0 -16px 34px rgba(31, 36, 48, 0.16);
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.drawer-title {
  font-size: 17px;
  line-height: 24px;
  font-weight: 800;
}

.drawer-close {
  width: 34px;
  height: 34px;
  border-radius: 17px;
  background: #f1f3f8;
  color: #596174;
  font-size: 20px;
  line-height: 34px;
}

.drawer-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-top: 14px;
}

.drawer-step {
  min-height: 32px;
  border-radius: 12px;
  background: #f1f3f8;
  color: #6f7583;
  font-size: 10px;
  line-height: 16px;
  text-align: center;
  padding: 6px 4px;
}

.drawer-step.active {
  background: #4533b7;
  color: #ffffff;
}

.drawer-body {
  margin-top: 14px;
  padding: 14px;
  border-radius: 16px;
  background: #f8f9fc;
}

.drawer-question,
.drawer-copy,
.drawer-status {
  display: block;
}

.drawer-question {
  font-size: 14px;
  line-height: 21px;
  font-weight: 800;
}

.drawer-copy {
  margin-top: 8px;
  color: #555d6c;
  font-size: 13px;
  line-height: 21px;
}

.drawer-status {
  margin-top: 10px;
  color: #0f8a4b;
  font-size: 13px;
  line-height: 20px;
  font-weight: 800;
}

.drawer-primary {
  width: 100%;
  height: 46px;
  margin-top: 14px;
  border-radius: 15px;
  background: #4533b7;
  color: #ffffff;
  font-size: 15px;
  font-weight: 800;
  line-height: 46px;
}

.c10-report {
  width: 390px;
  height: 844px;
  padding: 0 20px 70px;
  overflow: hidden;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fbfbff 0%, #f7f6ff 100%);
  color: #111935;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.c10-status {
  height: 34px;
  padding: 8px 0 0;
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
  color: #050816;
  font-size: 12px;
  font-weight: 700;
}

.c10-status text:last-child,
.c10-status span:last-child {
  position: relative;
  width: 38px;
  height: 13px;
  color: transparent;
}

.c10-status text:last-child::before,
.c10-status span:last-child::before {
  content: "";
  position: absolute;
  right: 15px;
  bottom: 2px;
  width: 15px;
  height: 10px;
  background:
    linear-gradient(#111 0 0) left 7px bottom / 2px 3px no-repeat,
    linear-gradient(#111 0 0) left 11px bottom / 2px 5px no-repeat,
    linear-gradient(#111 0 0) left 15px bottom / 2px 7px no-repeat;
}

.c10-status text:last-child::after,
.c10-status span:last-child::after {
  content: "";
  position: absolute;
  right: 0;
  bottom: 1px;
  width: 13px;
  height: 8px;
  border: 1px solid #111;
  border-radius: 2px;
  box-shadow: 3px 2px 0 -1px #111;
  background: linear-gradient(90deg, #111 0 9px, transparent 9px);
}

.c10-top {
  position: relative;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.c10-back {
  position: absolute;
  left: -2px;
  top: 7px;
  width: 24px;
  height: 32px;
  color: #111827;
  font-size: 34px;
  line-height: 28px;
}

.c10-title {
  font-size: 16px;
  line-height: 22px;
  font-weight: 900;
}

.c10-count {
  position: absolute;
  right: 0;
  top: 16px;
  color: #1b2545;
  font-size: 11px;
}

.c10-hero {
  position: relative;
  min-height: 278px;
}

.c10-heading,
.c10-time,
.c10-score-label,
.c10-score-note,
.c10-card-title,
.c10-card-sub,
.c10-priority-title,
.c10-priority-copy,
.c10-section-title,
.c10-section-sub,
.c10-question-body text,
.c10-question-body span {
  display: block;
}

.c10-heading {
  margin-top: 4px;
  font-size: 19px;
  line-height: 28px;
  font-weight: 900;
}

.c10-time {
  margin-top: 2px;
  color: #5f6680;
  font-size: 10px;
}

.c10-owl {
  position: absolute;
  right: -16px;
  top: 8px;
  width: 120px;
  height: 100px;
  box-shadow: 0 6px 16px rgba(12, 20, 36, 0.14);
}

.c10-owl-v13,
.c10-target-v13 {
  display: none;
}

body[data-screen="v13-full-report"] .c10-owl-core,
body[data-screen="v13-full-report"] .c10-target-core {
  display: none;
}

body[data-screen="v13-full-report"] .c10-owl-v13,
body[data-screen="v13-full-report"] .c10-target-v13 {
  display: block;
}

.c10-score-card {
  position: absolute;
  left: 0;
  top: 118px;
  width: 358px;
  min-height: 116px;
  padding: 18px 18px 16px 72px;
  border: 1px solid #ffb0a4;
  border-radius: 16px;
  background: linear-gradient(135deg, #fff8fb 0%, #fffefe 100%);
  box-sizing: border-box;
}

body[data-screen="full-report"] .c10-report {
  width: 390px;
  margin: 0;
  padding: 0 16px 70px;
}

body[data-screen="full-report"] .c10-hero {
  min-height: 260px;
}

body[data-screen="full-report"] .c10-heading {
  margin-top: 28px;
}

body[data-screen="full-report"] .c10-time {
  margin-top: 8px;
}

body[data-screen="full-report"] .c10-owl {
  right: -6px;
  top: -8px;
  width: 112px;
  height: 98px;
}

body[data-screen="full-report"] .c10-score-card {
  width: 358px;
  top: 106px;
  min-height: 154px;
}

body[data-screen="full-report"] .c10-score-label {
  position: relative;
  color: transparent;
}

body[data-screen="full-report"] .c10-score-label::before {
  content: "可追回分数";
  color: #6a55ff;
}

body[data-screen="full-report"] .c10-score-label::after {
  content: "可优先改善";
  display: inline-flex;
  height: 18px;
  margin-left: 8px;
  padding: 0 8px;
  border-radius: 8px;
  background: #f0edff;
  color: #9a8cff;
  align-items: center;
  font-size: 10px;
  line-height: 18px;
  font-weight: 700;
}

body[data-screen="full-report"] .c10-score-note {
  width: 220px;
}

body[data-screen="full-report"] .c10-card {
  width: 358px;
}

body[data-screen="full-report"] .c10-evidence {
  min-height: 224px;
  padding-top: 27px;
}

body[data-screen="full-report"] .c10-priority {
  min-height: 178px;
  padding-top: 27px;
}

body[data-screen="full-report"] .c10-evidence .c10-table {
  margin-top: 16px;
}

.c10-score-icon {
  position: absolute;
  left: 20px;
  top: 20px;
  width: 40px;
  height: 40px;
  padding: 8px;
  border-radius: 15px;
  background: #f1efff;
  box-sizing: border-box;
}

.c10-score-label {
  color: #6a55ff;
  font-size: 14px;
  font-weight: 800;
}

.c10-score-line {
  color: #704cff;
  font-weight: 900;
}

.c10-score-line text:first-child,
.c10-score-line span:first-child {
  font-size: 28px;
  line-height: 32px;
}

.c10-score-line text:last-child,
.c10-score-line span:last-child {
  margin-left: 4px;
  color: #f36f75;
  font-size: 16px;
}

.c10-score-note {
  margin-top: 6px;
  color: #53607a;
  font-size: 12px;
  line-height: 18px;
}

.c10-card {
  position: relative;
  width: 350px;
  margin-top: 16px;
  padding: 18px;
  border-radius: 16px;
  background: #ffffff;
  box-shadow: 0 7px 22px rgba(108, 91, 190, 0.09);
  box-sizing: border-box;
}

.c10-card-head {
  display: flex;
  gap: 9px;
  align-items: center;
}

.c10-card-head.tight {
  align-items: flex-start;
}

.c10-card-icon {
  width: 34px;
  height: 34px;
  padding: 8px;
  border-radius: 14px;
  background: #f1efff;
  box-sizing: border-box;
  flex: 0 0 34px;
}

.c10-card-title {
  color: #141d43;
  font-size: 14px;
  font-weight: 900;
}

.c10-card-sub,
.c10-priority-copy {
  margin-top: 4px;
  color: #59627c;
  font-size: 10px;
  line-height: 15px;
}

.c10-table {
  margin-top: 9px;
  display: grid;
  grid-template-columns: 44px 66px 66px 1fr;
  overflow: hidden;
  border-radius: 6px;
  background: #f8f7ff;
}

.c10-table text,
.c10-table span {
  min-height: 22px;
  padding: 6px 4px;
  border-right: 1px solid #eeebfa;
  border-bottom: 1px solid #eeebfa;
  color: #142143;
  text-align: center;
  font-size: 9px;
  line-height: 13px;
  box-sizing: border-box;
}

.c10-priority {
  min-height: 112px;
  padding-right: 104px;
}

.c10-priority-title {
  color: #111935;
  font-size: 14px;
  line-height: 20px;
  font-weight: 900;
}

.c10-target {
  position: absolute;
  right: 20px;
  top: 30px;
  width: 66px;
  height: 66px;
  border-radius: 0;
}

.c10-question-list {
  min-height: 244px;
  padding: 13px 12px 14px;
}

.c10-section-title {
  color: #111935;
  font-size: 15px;
  font-weight: 900;
}

.c10-section-sub {
  position: absolute;
  left: 82px;
  top: 16px;
  color: #53607a;
  font-size: 10px;
}

.c10-question {
  position: relative;
  display: grid;
  grid-template-columns: 25px 1fr;
  gap: 7px;
  margin-top: 13px;
}

.c10-question.second {
  padding-top: 11px;
  border-top: 1px solid #eeeafa;
}

.c10-number {
  width: 19px;
  height: 19px;
  border-radius: 10px;
  background: #7255ff;
  color: #ffffff;
  text-align: center;
  font-size: 12px;
  line-height: 19px;
  font-weight: 900;
}

.c10-question-head {
  display: flex;
  justify-content: space-between;
  gap: 6px;
  color: #111935;
  font-size: 12px;
  line-height: 18px;
  font-weight: 900;
}

.c10-badge {
  flex: 0 0 auto;
  height: 20px;
  padding: 0 8px;
  border-radius: 8px;
  font-size: 10px;
  line-height: 20px;
}

.c10-badge.red {
  color: #fa4157;
  background: #fff0f2;
}

.c10-badge.green {
  color: #16a05c;
  background: #e8fbef;
}

.c10-question-body text,
.c10-question-body span {
  margin-top: 3px;
  color: #26345c;
  font-size: 9px;
  line-height: 14px;
}

.c10-question-body .c10-blue {
  color: #5a4cff;
  font-weight: 800;
}

.c10-fix {
  width: 118px;
  height: 25px;
  margin-top: 8px;
  border-radius: 6px;
  background: linear-gradient(180deg, #775cff 0%, #5a3ff0 100%);
  color: #ffffff;
  font-size: 10px;
  line-height: 25px;
  text-align: center;
  font-weight: 800;
}

body[data-screen="full-report"] .c10-question-head {
  font-size: 10px;
  line-height: 15px;
}

body[data-screen="full-report"] .c10-question-body text,
body[data-screen="full-report"] .c10-question-body span {
  margin-top: 2px;
  font-size: 8px;
  line-height: 12px;
}

body[data-screen="full-report"] .c10-question-body .c10-blue {
  font-size: 10px;
  line-height: 14px;
}

body[data-screen="full-report"] .c10-fix {
  height: 24px;
  margin-top: 7px;
  line-height: 24px;
}

.c10-teacher {
  display: flex;
  gap: 9px;
  min-height: 62px;
  margin-bottom: 12px;
}

.writeback-only {
  display: none;
}

body[data-screen="v13-full-report"] .core-only {
  display: none;
}

body[data-screen="v13-full-report"] .writeback-only {
  display: block;
}

body[data-screen="v13-full-report"] .c10-question-list {
  min-height: 160px;
  margin-top: 4px;
}

body[data-screen="v13-full-report"] .c10-question-list.writeback-only {
  padding: 8px 0 0;
  background: transparent;
  box-shadow: none;
}

body[data-screen="v13-full-report"] .c10-question-list .c10-section-title {
  margin-left: 4px;
}

body[data-screen="v13-full-report"] .c10-question-list .c10-section-sub {
  left: 76px;
  top: 11px;
}

body[data-screen="v13-full-report"] .c10-question-list .c10-question {
  margin-top: 22px;
