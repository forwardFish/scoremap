page {
  min-height: 100%;
  background: #fdf8ff;
}

.v13-report-page {
  min-height: 100vh;
  background: #fdf8ff;
  color: #1c1b23;
  font-family: "Plus Jakarta Sans", Arial, sans-serif;
}

.v13-topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  height: 112rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fdf8ff;
  box-shadow: 0 2rpx 10rpx rgba(90, 69, 203, 0.06);
}

.topbar-title {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 700;
  color: #5a45cb;
}

.icon-button {
  width: 80rpx;
  height: 80rpx;
  padding: 0;
  border-radius: 40rpx;
  color: #5a45cb;
  background: transparent;
  font-size: 26rpx;
  line-height: 80rpx;
  font-weight: 700;
}

.icon-button::after,
.bottom-actions button::after {
  border: 0;
}

.report-scroll {
  height: calc(100vh - 112rpx);
  box-sizing: border-box;
  padding: 32rpx 32rpx 176rpx;
}

.hero-card {
  position: relative;
  min-height: 336rpx;
  padding: 48rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 48rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f7f1fd 100%);
  box-shadow: 0 30rpx 60rpx rgba(90, 69, 203, 0.06);
}

.hero-card::after {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 999rpx;
  background: rgba(229, 222, 255, 0.62);
  filter: blur(20rpx);
  content: "";
}

.hero-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  padding-right: 24rpx;
}

.hero-title {
  display: block;
  font-size: 54rpx;
  line-height: 68rpx;
  font-weight: 700;
}

.hero-summary {
  display: block;
  margin-top: 16rpx;
  font-size: 30rpx;
  line-height: 44rpx;
  color: #474554;
}

.hero-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.status-pill,
.quota-pill {
  display: inline-flex;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 700;
}

.status-pill {
  color: #006a35;
  background: rgba(0, 106, 53, 0.1);
}

.quota-pill {
  color: #442bb5;
  background: #e5deff;
}

.local-mascot {
  position: relative;
  z-index: 1;
  width: 168rpx;
  height: 168rpx;
  border-radius: 52rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(145deg, #ffffff, #e5deff);
  box-shadow: 0 20rpx 44rpx rgba(92, 71, 205, 0.12);
  color: #442bb5;
  font-weight: 800;
}

.mascot-cap {
  font-size: 44rpx;
  line-height: 54rpx;
}

.mascot-face {
  margin-top: -4rpx;
  font-size: 24rpx;
  line-height: 30rpx;
  color: #006a35;
}

.section-title {
  margin: 56rpx 0 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 700;
}

.title-marker {
  width: 12rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #5a45cb;
}

.title-marker.secondary {
  background: #fc9d41;
}

.report-row,
.wrong-card {
  margin-bottom: 24rpx;
  border: 2rpx solid #ebe6f2;
  background: #ffffff;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.02);
}

.report-row {
  min-height: 128rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
}

.row-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5a45cb;
  background: rgba(90, 69, 203, 0.1);
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
}

.row-icon.tone-tertiary {
  color: #006a35;
  background: rgba(0, 106, 53, 0.1);
}

.row-icon.tone-secondary {
  color: #8f4e00;
  background: rgba(143, 78, 0, 0.1);
}

.row-copy {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.row-title,
.wrong-name {
  display: block;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.row-summary,
.wrong-stem {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #474554;
}

.row-chevron {
  color: #787585;
  font-size: 24rpx;
  font-weight: 700;
}

.wrong-card {
  position: relative;
  padding: 32rpx;
  border-radius: 40rpx;
  border-left-width: 8rpx;
}

.severity-high {
  border-left-color: #fc9d41;
}

.severity-medium {
  border-left-color: #5a45cb;
}

.wrong-main,
.wrong-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.wrong-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #5a45cb;
  background: #ebe6f2;
  font-size: 22rpx;
  font-weight: 800;
}

.wrong-copy {
  flex: 1;
  min-width: 0;
}

.wrong-name {
  flex: 1;
}

.mastery {
  flex-shrink: 0;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  color: #6d3a00;
  background: #ffdcc2;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.wrong-stem {
  padding-right: 48rpx;
}

.wrong-chevron {
  position: absolute;
  right: 24rpx;
  bottom: 30rpx;
  color: #787585;
  font-size: 24rpx;
  font-weight: 700;
}

.disclaimer {
  padding: 32rpx 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: rgba(71, 69, 84, 0.72);
  font-size: 22rpx;
  line-height: 32rpx;
}

.disclaimer-icon {
  font-size: 24rpx;
  font-weight: 700;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 48rpx;
  background: rgba(253, 248, 255, 0.92);
  border-top: 2rpx solid rgba(201, 196, 214, 0.4);
}

.bottom-actions button {
  flex: 1;
  height: 88rpx;
  margin: 0;
  border-radius: 28rpx;
  font-size: 26rpx;
  line-height: 88rpx;
  font-weight: 700;
}

.share-button {
  color: #ffffff;
  background: #5a45cb;
  box-shadow: 0 16rpx 36rpx rgba(90, 69, 203, 0.22);
}

.pdf-button {
  color: #5a45cb;
  background: #ffffff;
  border: 4rpx solid #5a45cb;
}
