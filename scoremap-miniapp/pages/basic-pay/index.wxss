page {
  min-height: 100%;
  background: #f8f9ff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.pay-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  padding: 28px 24px 0;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(180deg, #f1efff 0%, #f8f9ff 100%);
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.top-bar {
  height: 44px;
  display: flex;
  align-items: center;
}

.back-button {
  width: 34px;
  height: 40px;
  color: #6044dc;
  font-size: 36px;
}

.page-title {
  flex: 1;
  margin-right: 34px;
  text-align: center;
  font-size: 20px;
  font-weight: 900;
}

.pay-card {
  margin-top: 58px;
  padding: 42px 28px 34px;
  border-radius: 28px;
  background: #ffffff;
  box-shadow: 0 18px 48px rgba(90, 70, 180, 0.12);
  text-align: center;
}

.pay-icon {
  width: 76px;
  height: 76px;
}

.title,
.price,
.copy {
  display: block;
}

.title {
  margin-top: 18px;
  color: #111827;
  font-size: 23px;
  font-weight: 900;
}

.price {
  margin-top: 15px;
  color: #6044dc;
  font-size: 44px;
  font-weight: 900;
}

.copy {
  margin-top: 14px;
  color: #667085;
  font-size: 14px;
  line-height: 23px;
}

.benefits {
  margin-top: 28px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 9px;
}

.benefits text {
  height: 36px;
  border-radius: 12px;
  background: #f3efff;
  color: #6044dc;
  font-size: 12px;
  font-weight: 800;
  line-height: 36px;
}

.pay-button {
  position: absolute;
  left: 30px;
  right: 30px;
  bottom: 22px;
  height: 54px;
  border-radius: 27px;
  background: linear-gradient(90deg, #8e6bff 0%, #6044dc 100%);
  color: #ffffff;
  font-size: 17px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10px 24px rgba(96, 68, 220, 0.25);
}
