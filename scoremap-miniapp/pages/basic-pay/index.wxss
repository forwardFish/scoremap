page { min-height: 100%; background: #f8f9ff; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; }
button::after { border: 0; }

.basic-pay-screen {
  min-height: 100vh;
  background: #f8f9ff;
  color: #1f2937;
  box-sizing: border-box;
  padding-bottom: 232rpx;
}

.basic-pay-shell {
  padding: 40rpx 34rpx 34rpx;
  box-sizing: border-box;
}

.basic-pay-header {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.basic-pay-back {
  width: 58rpx;
  height: 58rpx;
  position: relative;
}

.basic-pay-back::before {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 14rpx;
  width: 22rpx;
  height: 22rpx;
  border-left: 6rpx solid #1f2937;
  border-bottom: 6rpx solid #1f2937;
  border-radius: 3rpx;
  transform: rotate(45deg);
}

.basic-pay-brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-bot {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-bot-face {
  width: 36rpx;
  height: 30rpx;
  border-radius: 10rpx;
  background: #7c4dff;
  position: relative;
}

.brand-bot-face::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: -9rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #7c4dff;
}

.brand-eye {
  position: absolute;
  top: 12rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #fff;
}

.brand-eye.left { left: 10rpx; }
.brand-eye.right { right: 10rpx; }

.basic-pay-title {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.basic-pay-spacer { width: 58rpx; }

.pay-intro {
  margin: 26rpx 0 44rpx;
  color: #6b7280;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
}

.pay-accent {
  color: #7c4dff;
  font-weight: 900;
}

.pay-steps {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  margin-bottom: 42rpx;
}

.pay-step {
  width: 144rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #9ca3af;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.step-number {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  border: 4rpx solid #e5e7eb;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 900;
}

.pay-step.done .step-number {
  color: #10b981;
  border-color: #d1fae5;
}

.pay-step.active {
  color: #7c4dff;
}

.pay-step.active .step-number {
  color: #fff;
  border-color: #7c4dff;
  background: #7c4dff;
  box-shadow: 0 12rpx 22rpx rgba(124, 77, 255, 0.24);
}

.step-line {
  width: 68rpx;
  height: 4rpx;
  margin-top: 27rpx;
  background: #e5e7eb;
}

.step-line.done,
.step-line.active { background: #7c4dff; }

.pay-summary-card {
  min-height: 236rpx;
  border-radius: 42rpx;
  background: #fff;
  box-shadow: 0 20rpx 58rpx rgba(124, 77, 255, 0.08);
  padding: 34rpx 30rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  margin-bottom: 34rpx;
}

.pay-summary-card::before {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 230rpx;
  height: 230rpx;
  border-radius: 50%;
  background: #f0e6ff;
}

.summary-copy {
  width: 66%;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  position: relative;
  z-index: 2;
}

.summary-title {
  color: #111827;
  font-size: 38rpx;
  line-height: 1.18;
  font-weight: 900;
}

.summary-desc {
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.48;
}

.summary-badge {
  align-self: flex-start;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #10b981;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.check-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #10b981;
  position: relative;
}

.check-dot::before {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 3rpx;
  width: 7rpx;
  height: 10rpx;
  border-right: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(45deg);
}

.summary-figure {
  position: absolute;
  right: 18rpx;
  bottom: 10rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #eadbff, #cdb8ff);
}

.summary-figure::before {
  content: "";
  position: absolute;
  left: 38rpx;
  top: 38rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #b388ff;
}

.figure-cap {
  position: absolute;
  right: 22rpx;
  top: 24rpx;
  width: 68rpx;
  height: 26rpx;
  border-radius: 5rpx;
  background: #1f2937;
  transform: rotate(16deg);
  z-index: 3;
}

.figure-glasses {
  position: absolute;
  left: 46rpx;
  top: 78rpx;
  display: flex;
  gap: 10rpx;
  z-index: 4;
}

.figure-glasses view {
  width: 24rpx;
  height: 16rpx;
  border: 5rpx solid #1f2937;
  border-radius: 12rpx;
}

.pay-preview-card {
  border-radius: 38rpx;
  background: #fff;
  box-shadow: 0 18rpx 52rpx rgba(31, 41, 55, 0.06);
  padding: 26rpx 10rpx 8rpx;
  box-sizing: border-box;
}

.pay-card-title {
  display: block;
  margin: 0 18rpx 10rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #111827;
}

.pay-preview-row {
  min-height: 104rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  border-bottom: 2rpx solid #f3f4f6;
}

.pay-preview-row.locked { opacity: 0.48; }
.pay-preview-row.last { border-bottom: 0; }

.pay-row-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
}

.pay-row-icon.red { background: #fef2f2; color: #ef4444; }
.pay-row-icon.green { background: #ecfdf5; color: #10b981; }
.pay-row-icon.blue { background: #eff6ff; color: #2563eb; }
.pay-row-icon.amber { background: #fffbeb; color: #f59e0b; }

.lock-dot::before {
  content: "";
  width: 24rpx;
  height: 18rpx;
  border: 5rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.pay-row-title,
.pay-row-desc {
  display: block;
}

.pay-row-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.pay-row-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
  line-height: 1.35;
}

.basic-pay-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 22rpx 34rpx 42rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 -16rpx 42rpx rgba(31, 41, 55, 0.06);
  box-sizing: border-box;
}

.price-row {
  height: 62rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  color: #7c4dff;
  margin-bottom: 14rpx;
}

.price-value {
  font-size: 62rpx;
  line-height: 1;
  font-weight: 900;
}

.price-unit {
  margin-left: 6rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.basic-pay-submit {
  width: 100%;
  height: 98rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8e6dfe 0%, #714afe 100%);
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 32rpx rgba(124, 77, 255, 0.26);
}
