page {
  min-height: 100%;
  background: #ffffff;
  color: #101336;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.my-page {
  position: relative;
  width: 650rpx;
  min-height: 100vh;
  margin: 4rpx auto 0;
  padding: 14rpx 0 112rpx;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 24rpx 24rpx 0 0;
  background: linear-gradient(180deg, #f7f5ff 0%, #ffffff 52%, #f8f7ff 100%);
}

.v143-c11-visual,
.v143-hotspot {
  display: none;
}

body[data-screen="my"] .my-page,
body[data-screen="my-stitch"] .my-page {
  width: 390px;
  height: 844px;
  min-height: 844px;
  margin: 0;
  padding: 0;
  overflow: hidden;
  border-radius: 0;
  background: #ffffff;
}

body[data-screen="my"] .status-bar,
body[data-screen="my"] .page-header,
body[data-screen="my"] .upload-card,
body[data-screen="my"] .filter-tabs,
body[data-screen="my"] .report-list,
body[data-screen="my"] .bottom-tabs,
body[data-screen="my-stitch"] .status-bar,
body[data-screen="my-stitch"] .page-header,
body[data-screen="my-stitch"] .upload-card,
body[data-screen="my-stitch"] .filter-tabs,
body[data-screen="my-stitch"] .report-list,
body[data-screen="my-stitch"] .bottom-tabs {
  display: none;
}

body[data-screen="my"] .v143-c11-visual,
body[data-screen="my-stitch"] .v143-c11-visual {
  position: relative;
  display: block;
  width: 390px;
  height: 844px;
  overflow: hidden;
}

body[data-screen="my"] .v143-hotspot,
body[data-screen="my-stitch"] .v143-hotspot {
  position: absolute;
  display: block;
  background: transparent;
}

body[data-screen="my"] .v143-hotspot-back,
body[data-screen="my-stitch"] .v143-hotspot-back {
  left: 43px;
  top: 48px;
  width: 30px;
  height: 34px;
}

body[data-screen="my"] .v143-hotspot-new,
body[data-screen="my-stitch"] .v143-hotspot-new {
  left: 39px;
  top: 90px;
  width: 310px;
  height: 75px;
}

body[data-screen="my"] .v143-hotspot-view-report,
body[data-screen="my-stitch"] .v143-hotspot-view-report {
  left: 161px;
  top: 366px;
  width: 82px;
  height: 37px;
}

body[data-screen="my"] .v143-hotspot-repair,
body[data-screen="my-stitch"] .v143-hotspot-repair {
  left: 250px;
  top: 366px;
  width: 105px;
  height: 37px;
}

body[data-screen="my"] .v143-hotspot-home-tab,
body[data-screen="my-stitch"] .v143-hotspot-home-tab {
  left: 64px;
  top: 788px;
  width: 60px;
  height: 50px;
}

body[data-screen="my"] .v143-hotspot-report-tab,
body[data-screen="my-stitch"] .v143-hotspot-report-tab {
  left: 164px;
  top: 788px;
  width: 70px;
  height: 50px;
}

body[data-screen="my"] .v143-hotspot-profile-tab,
body[data-screen="my-stitch"] .v143-hotspot-profile-tab {
  left: 273px;
  top: 788px;
  width: 58px;
  height: 50px;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 46rpx;
  padding: 0 30rpx;
  font-size: 21rpx;
  font-weight: 700;
  color: #05051f;
}

.phone-icons {
  letter-spacing: 4rpx;
  font-size: 18rpx;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 78rpx;
  padding: 0 20rpx;
}

.back-button,
.header-spacer {
  width: 68rpx;
  height: 68rpx;
}

.back-button {
  font-size: 54rpx;
  line-height: 62rpx;
  text-align: center;
  color: #101336;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.upload-card,
.report-card {
  border: 1rpx solid rgba(113, 101, 223, 0.08);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 46rpx rgba(80, 70, 170, 0.08);
}

.upload-card {
  display: flex;
  align-items: center;
  min-height: 150rpx;
  margin: 26rpx 22rpx 36rpx;
  padding: 28rpx 24rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
}

.upload-icon {
  width: 44rpx;
  height: 64rpx;
  border-radius: 10rpx;
  background: linear-gradient(180deg, #e7f0ff 0%, #5891ff 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 64rpx;
  text-align: center;
}

.upload-icon-image {
  width: 28rpx;
  height: 28rpx;
}

.upload-copy {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.upload-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: #12163c;
}

.upload-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #7b7fa8;
  font-size: 22rpx;
}

.upload-button {
  width: 66rpx;
  height: 66rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #d9c9ff 0%, #7358ff 100%);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 66rpx;
  text-align: center;
  box-shadow: 0 10rpx 24rpx rgba(113, 88, 255, 0.22);
}

.filter-tabs {
  display: flex;
  align-items: center;
  gap: 39rpx;
  height: 54rpx;
  margin: 0 22rpx 20rpx;
  border-bottom: 1rpx solid #e6e4ff;
  white-space: nowrap;
}

.filter-tab {
  position: relative;
  height: 54rpx;
  color: #192050;
  font-size: 22rpx;
  line-height: 52rpx;
  text-align: center;
}

.filter-tab.active {
  color: #4a34fb;
  font-weight: 700;
}

.filter-tab.active::after {
  content: "";
  position: absolute;
  left: 3rpx;
  right: 3rpx;
  bottom: -1rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #4a34fb;
}

.report-list {
  margin: 0 14rpx;
}

.report-card {
  position: relative;
  margin-bottom: 22rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.full-card {
  min-height: 368rpx;
}

.compact-card {
  min-height: 188rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-title {
  color: #11143a;
  font-size: 28rpx;
  font-weight: 700;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  font-size: 19rpx;
  line-height: 38rpx;
  white-space: nowrap;
}

.status-pill.full {
  background: #dcf8e7;
  color: #18a358;
}

.status-pill.basic {
  background: #e9f0ff;
  color: #5579ff;
}

.status-pill.preview {
  background: #fff1df;
  color: #ff9a15;
}

.status-pill.analyzing {
  background: #f0e7ff;
  color: #654dff;
}

.report-time {
  display: block;
  margin-top: 15rpx;
  color: #6b6f98;
  font-size: 21rpx;
}

.full-content {
  display: flex;
  margin-top: 22rpx;
}

.paper-thumb {
  position: relative;
  width: 144rpx;
  height: 142rpx;
  border: 1rpx solid #ececff;
  border-radius: 13rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(90, 83, 190, 0.08);
}

.paper-line {
  position: absolute;
  left: 24rpx;
  top: 28rpx;
  width: 86rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #6b63ff;
}

.paper-line.wide {
  width: 96rpx;
  background: #b9c5ff;
}

.paper-line.short {
  top: 56rpx;
  width: 66rpx;
  background: #d6dafb;
}

.paper-line.bottom {
  top: 104rpx;
  width: 82rpx;
  background: #d6dafb;
}

.answer-dot {
  position: absolute;
  left: 24rpx;
  top: 78rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff5f82;
}

.answer-dot.second {
  top: 96rpx;
  background: #ffb13d;
}

.report-summary {
  flex: 1;
  margin-left: 26rpx;
  padding-top: 12rpx;
  color: #53577c;
  font-size: 22rpx;
  line-height: 1.6;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
}

.primary-small,
.secondary-small,
.outline-button {
  height: 66rpx;
  border-radius: 32rpx;
  padding: 0 34rpx;
  font-size: 22rpx;
  line-height: 66rpx;
  text-align: center;
}

.primary-small {
  background: linear-gradient(135deg, #7a5bff 0%, #4c37f4 100%);
  color: #ffffff;
}

.secondary-small,
.outline-button {
  border: 1rpx solid #7b68ff;
  color: #604cff;
  background: #ffffff;
}

.outline-button {
  margin-top: 22rpx;
}

.compact-card .report-summary {
  display: block;
  margin: 12rpx 0 0;
  padding: 0;
  font-size: 22rpx;
}

.analyzing-card {
  padding-right: 116rpx;
}

.progress-ring {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  width: 70rpx;
  height: 70rpx;
  border: 12rpx solid #e5e8ff;
  border-top-color: #7488ff;
  border-radius: 50%;
  box-sizing: border-box;
  color: #5a6dff;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.bottom-tabs {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  height: 104rpx;
  border-top: 1rpx solid #ebeafd;
  background: rgba(255, 255, 255, 0.98);
}

.bottom-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #a2a5bb;
  font-size: 20rpx;
}

.bottom-tab.active {
  color: #4c37f4;
}

.tab-icon {
  display: block;
  margin-bottom: 4rpx;
  font-size: 28rpx;
  line-height: 30rpx;
}

body[data-screen="my"] .status-bar,
body[data-screen="my"] .page-header,
body[data-screen="my"] .upload-card,
body[data-screen="my"] .filter-tabs,
body[data-screen="my"] .report-list,
body[data-screen="my"] .bottom-tabs,
body[data-screen="my-stitch"] .status-bar,
body[data-screen="my-stitch"] .page-header,
body[data-screen="my-stitch"] .upload-card,
body[data-screen="my-stitch"] .filter-tabs,
body[data-screen="my-stitch"] .report-list,
body[data-screen="my-stitch"] .bottom-tabs {
  display: flex;
}

body[data-screen="my"] .report-list,
body[data-screen="my-stitch"] .report-list {
  display: block;
}

body[data-screen="my"] .bottom-tabs,
body[data-screen="my-stitch"] .bottom-tabs {
  display: grid;
}

body[data-screen="my"] .v143-c11-visual,
body[data-screen="my-stitch"] .v143-c11-visual {
  display: none;
}

body[data-screen="my"] .my-page,
body[data-screen="my-stitch"] .my-page {
  background: #f7f5ff;
}

body[data-screen="my"] .status-bar,
body[data-screen="my-stitch"] .status-bar {
  visibility: hidden;
}

body[data-screen="my"] .page-header,
body[data-screen="my-stitch"] .page-header {
  margin-top: 14px;
}

body[data-screen="my"] .bottom-tabs,
body[data-screen="my-stitch"] .bottom-tabs {
  display: none;
}

body[data-screen="my"] .upload-card,
body[data-screen="my-stitch"] .upload-card {
  min-height: 90px;
  margin-top: 22px;
  margin-bottom: 42px;
  border-radius: 16px;
}

body[data-screen="my"] .upload-icon,
body[data-screen="my-stitch"] .upload-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: #f0efff;
  display: flex;
  align-items: center;
  justify-content: center;
}

body[data-screen="my"] .upload-icon-image,
body[data-screen="my-stitch"] .upload-icon-image {
  width: 22px;
  height: 22px;
}

body[data-screen="my"] .upload-button,
body[data-screen="my-stitch"] .upload-button {
  font-size: 24px;
  line-height: 33px;
  text-align: center;
}

body[data-screen="my"] .filter-tabs,
body[data-screen="my-stitch"] .filter-tabs {
  margin-bottom: 28px;
}

body[data-screen="my"] .report-list,
body[data-screen="my-stitch"] .report-list {
  margin: 0 16px;
}

body[data-screen="my"] .report-card,
body[data-screen="my-stitch"] .report-card {
  border-radius: 16px;
}

body[data-screen="my"] .full-card,
body[data-screen="my-stitch"] .full-card {
  min-height: 292px;
  padding-top: 24px;
}

body[data-screen="my"] .paper-thumb,
body[data-screen="my-stitch"] .paper-thumb {
  width: 102px;
  height: 112px;
  border-radius: 10px;
  background: linear-gradient(180deg, #f8f9ff 0%, #ffffff 100%);
}

body[data-screen="my"] .paper-line,
body[data-screen="my-stitch"] .paper-line {
  left: 18px;
}

body[data-screen="my"] .report-summary,
body[data-screen="my-stitch"] .report-summary {
  margin-left: 20px;
  padding-top: 8px;
  font-size: 14px;
  line-height: 1.6;
}

body[data-screen="my"] .paper-line,
body[data-screen="my"] .answer-dot,
body[data-screen="my-stitch"] .paper-line,
body[data-screen="my-stitch"] .answer-dot {
  opacity: 0.15;
}
