<view class="entry-page">
  <view class="success-card">
    <image class="success-icon" src="/assets/icons/success-check-green.png" mode="aspectFit" />
    <text class="title">完整报告已解锁</text>
    <text class="copy">已生成完整提分报告，包含核心五卡、关键错题修复和家长行动建议。</text>
    <view class="summary-grid">
      <view><text class="num">5</text><text>核心卡片</text></view>
      <view><text class="num">7天</text><text>行动计划</text></view>
      <view><text class="num">AI</text><text>错题修复</text></view>
    </view>
  </view>

  <button class="view-button" data-action="view" bindtap="onTap">查看完整报告</button>
  <button class="save-button" data-action="save" bindtap="onTap">保存报告</button>
  <button class="home-button" data-action="home" bindtap="onTap">返回首页</button>
</view>
