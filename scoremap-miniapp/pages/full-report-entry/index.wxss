page {
  min-height: 100%;
  background: #f8f9ff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.entry-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  padding: 88px 28px 0;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(180deg, #f0fff7 0%, #f8f9ff 45%, #ffffff 100%);
  color: #111827;
  font-family: "Inter", "Microsoft YaHei UI", "Microsoft YaHei", "PingFang SC", "Noto Sans SC", "DengXian", "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, "Helvetica Neue", Arial, sans-serif;
}

.success-card {
  padding: 46px 26px 36px;
  border-radius: 28px;
  background: #ffffff;
  box-shadow: 0 18px 48px rgba(45, 150, 93, 0.12);
  text-align: center;
}

.success-icon {
  width: 82px;
  height: 82px;
}

.title,
.copy {
  display: block;
}

.title {
  margin-top: 18px;
  color: #111827;
  font-size: 24px;
  font-weight: 700;
}

.copy {
  margin-top: 14px;
  color: #667085;
  font-size: 14px;
  line-height: 23px;
}

.summary-grid {
  margin-top: 30px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
}

.summary-grid view {
  min-height: 70px;
  border-radius: 16px;
  background: #f4f7ff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 12px;
  font-weight: 700;
}

.num {
  color: #6044dc;
  font-size: 20px;
  font-weight: 700;
}

.view-button,
.save-button,
.home-button {
  position: absolute;
  left: 28px;
  right: 28px;
  height: 52px;
  border-radius: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
}

.view-button {
  top: 652px;
  background: #6044dc;
  color: #ffffff;
}

.save-button {
  top: 720px;
  color: #6044dc;
  border: 1px solid #6044dc;
}

.home-button {
  top: 782px;
  color: #667085;
}
