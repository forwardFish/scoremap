page { min-height: 100%; background: #f6f7fc; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; text-align: left; }
button::after { border: 0; }

.entry-screen {
  min-height: 100vh;
  background: #f6f7fc;
  color: #111827;
  padding-bottom: 236rpx;
  box-sizing: border-box;
}

.entry-header {
  height: 108rpx;
  padding: 18rpx 34rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(246, 247, 252, 0.94);
}

.entry-back {
  width: 64rpx;
  height: 64rpx;
  position: relative;
}

.entry-back::before {
  content: "";
  position: absolute;
  left: 19rpx;
  top: 15rpx;
  width: 25rpx;
  height: 25rpx;
  border-left: 7rpx solid #111827;
  border-bottom: 7rpx solid #111827;
  border-radius: 3rpx;
  transform: rotate(45deg);
}

.entry-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.entry-header-spacer { width: 64rpx; height: 64rpx; }
.entry-main { padding: 26rpx 30rpx 0; box-sizing: border-box; }

.entry-hero {
  min-height: 516rpx;
  border-radius: 42rpx;
  background: linear-gradient(135deg, #fff 0%, #fbfbfe 100%);
  box-shadow: 0 16rpx 42rpx rgba(31, 41, 55, 0.04);
  padding: 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.entry-hero-copy {
  width: 62%;
  position: relative;
  z-index: 2;
}

.entry-report-title {
  display: block;
  color: #111827;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 900;
  margin-bottom: 26rpx;
}

.entry-summary {
  display: block;
  color: #475467;
  font-size: 29rpx;
  line-height: 1.65;
  margin-bottom: 42rpx;
}

.entry-ready {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 50rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #e8f8ee;
  color: #22c55e;
  font-size: 24rpx;
  font-weight: 900;
}

.ready-check {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: #22c55e;
  position: relative;
}

.ready-check::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 5rpx;
  width: 8rpx;
  height: 12rpx;
  border-right: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
}

.entry-mascot {
  position: absolute;
  right: 38rpx;
  bottom: 38rpx;
  width: 214rpx;
  height: 214rpx;
  background: radial-gradient(circle at 50% 48%, #34455a 0, #17202b 44%, #05070a 72%);
  overflow: hidden;
}

.lion-face {
  position: absolute;
  left: 62rpx;
  top: 54rpx;
  width: 92rpx;
  height: 100rpx;
  border-radius: 48%;
  background: linear-gradient(180deg, #e3c98a 0%, #6a5137 100%);
  z-index: 2;
}

.lion-mane {
  position: absolute;
  left: 36rpx;
  top: 28rpx;
  width: 144rpx;
  height: 156rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #1e293b 0 40%, #0f172a 42% 70%, transparent 72%);
}

.entry-section-title {
  display: block;
  margin: 54rpx 8rpx 28rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.entry-list {
  border-radius: 38rpx;
  background: #fff;
  box-shadow: 0 14rpx 40rpx rgba(31, 41, 55, 0.04);
  overflow: hidden;
}

.entry-row {
  width: 100%;
  min-height: 126rpx;
  padding: 24rpx 34rpx;
  box-sizing: border-box;
  border-bottom: 2rpx solid #f3f4f6;
  display: flex;
  align-items: center;
}

.entry-row.last { border-bottom: 0; }

.row-thumb {
  width: 72rpx;
  height: 72rpx;
  margin-right: 32rpx;
  border-radius: 4rpx;
  position: relative;
  flex: 0 0 auto;
}

.row-thumb::before {
  content: "";
  position: absolute;
  left: -8rpx;
  top: -8rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  z-index: -1;
  opacity: 0.8;
}

.row-thumb.red { background: radial-gradient(circle, #111827 0 42%, #0b111b 46%); }
.row-thumb.red::before { background: #fff1f2; }
.row-thumb.green { background: radial-gradient(circle, #23170f 0 40%, #080606 42%); }
.row-thumb.green::before { background: #ecfdf5; }
.row-thumb.blue { background: radial-gradient(circle, #f59e0b 0 12%, #1f2937 16% 58%, #080606 62%); }
.row-thumb.blue::before { background: #eff6ff; }
.row-thumb.yellow { background: radial-gradient(circle, #334155 0 44%, #101827 48%); }
.row-thumb.yellow::before { background: #fefce8; }

.row-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 9rpx;
}

.row-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.15;
}

.row-desc {
  color: #667085;
  font-size: 25rpx;
  line-height: 1.35;
}

.row-arrow {
  color: #98a2b3;
  font-size: 58rpx;
  font-weight: 300;
  line-height: 1;
  margin-left: 18rpx;
}

.entry-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 24rpx 30rpx 36rpx;
  box-sizing: border-box;
  background: rgba(246, 247, 252, 0.96);
}

.entry-action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.entry-primary,
.entry-secondary,
.entry-home {
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  font-size: 29rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.entry-primary {
  color: #fff;
  background: linear-gradient(90deg, #816afa 0%, #6e5df6 100%);
  box-shadow: 0 12rpx 24rpx rgba(110, 93, 246, 0.18);
}

.entry-secondary,
.entry-home {
  color: #6e5df6;
  background: #fff;
  border: 3rpx solid #6e5df6;
}

.entry-home { width: 100%; }

.doc-icon,
.download-icon,
.home-icon {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.doc-icon {
  border: 4rpx solid currentColor;
  border-radius: 4rpx;
  box-sizing: border-box;
}
.doc-icon::before,
.doc-icon::after {
  content: "";
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  height: 3rpx;
  background: currentColor;
}
.doc-icon::before { top: 8rpx; }
.doc-icon::after { top: 16rpx; }

.download-icon::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 0;
  width: 4rpx;
  height: 18rpx;
  background: currentColor;
}
.download-icon::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 14rpx;
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(-45deg);
}

.home-icon::before {
  content: "";
  position: absolute;
  left: 2rpx;
  top: 10rpx;
  width: 24rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  box-sizing: border-box;
}
.home-icon::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
}
