<view class="basic-result-page">
  <view class="status-bar">
    <text>9:41</text>
    <text>wifi</text>
  </view>

  <view class="top-bar">
    <button class="back-button" bindtap="onBack">‹</button>
    <text class="page-title">初步分析报告</text>
    <text class="page-subtitle">初一数学月考分析</text>
  </view>

  <scroll-view class="result-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="hero-card">
      <view class="hero-copy-wrap">
        <text class="hero-title">初步分析已生成</text>
        <text class="hero-copy">整体基础较好，计算粗心和几何证明是本次失分的主要原因。</text>
        <view class="success-pill">
          <image class="success-pill-icon" src="/assets/icons/success-check-green.png" mode="aspectFit" />
          <text>初步分析已生成</text>
        </view>
      </view>
      <view class="hero-visual" aria-hidden="true">
        <image class="hero-report-icon" src="/assets/icons/report-chart-clipboard.png" mode="aspectFit" />
        <image class="hero-owl" src="/assets/icons/owl-teacher-pointer-transparent.png" mode="aspectFit" />
        <image class="hero-shield-icon" src="/assets/clean-icons/shield-check-purple.png" mode="aspectFit" />
      </view>
    </view>

    <view class="summary-card">
      <view class="summary-row">
        <view class="summary-icon target">
          <image src="/assets/icons/target-purple.png" mode="aspectFit" />
        </view>
        <text class="summary-title">主要丢分点</text>
        <text class="summary-copy">计算失误、几何证明</text>
      </view>
      <view class="summary-row">
        <view class="summary-icon trend">
          <image src="/assets/icons/growth-chart-green.png" mode="aspectFit" />
        </view>
        <text class="summary-title">优先补弱点</text>
        <text class="summary-copy">优先提升几何证明能力</text>
      </view>
      <view class="summary-row">
        <view class="summary-icon doc">
          <image src="/assets/icons/document-list-purple.png" mode="aspectFit" />
        </view>
        <text class="summary-title">答题质量概览</text>
        <text class="summary-copy">基础题较稳，步骤规范性一般</text>
      </view>
      <view class="summary-row no-border">
        <view class="summary-icon idea">
          <image src="/assets/icons/idea-bulb-soft.png" mode="aspectFit" />
        </view>
        <text class="summary-title">简短建议</text>
        <text class="summary-copy">先修复高频错因，再看完整建议</text>
      </view>
    </view>

    <view class="locked-card">
      <view class="locked-heading">
        <image class="locked-heading-icon" src="/assets/icons/lock-purple.png" mode="aspectFit" />
        <text>完整报告解锁后可查看</text>
      </view>
      <view class="locked-row">
        <image class="locked-row-icon" src="/assets/icons/lock-purple.png" mode="aspectFit" />
        <text>详细丢分点分析</text>
        <text>›</text>
      </view>
      <view class="locked-row">
        <image class="locked-row-icon" src="/assets/icons/lock-purple.png" mode="aspectFit" />
        <text>优先补弱顺序</text>
        <text>›</text>
      </view>
      <view class="locked-row">
        <image class="locked-row-icon" src="/assets/icons/lock-purple.png" mode="aspectFit" />
        <text>7天行动建议</text>
        <text>›</text>
      </view>
      <view class="locked-row">
        <image class="locked-row-icon" src="/assets/icons/lock-purple.png" mode="aspectFit" />
        <text>完整学习建议</text>
        <text>›</text>
      </view>
      <view class="locked-row">
        <image class="locked-row-icon" src="/assets/icons/lock-purple.png" mode="aspectFit" />
        <text>关键错题修复 / 同类题练习入口</text>
        <text>›</text>
      </view>
    </view>

    <view class="upgrade-card">
      <view class="price-lock">
        <image class="price-lock-icon" src="/assets/icons/shield-check-purple.png" mode="aspectFit" />
      </view>
      <view class="price-line">
        <text>9.9</text>
        <text>元</text>
        <text>已完成初判，可立即解锁完整提分报告</text>
      </view>
      <view class="mini-benefits">
        <text>完整报告</text>
        <text>7天建议</text>
        <text>错题修复</text>
      </view>
      <button class="unlock-button" data-action="unlock" bindtap="onTap">立即支付 9.9元</button>
      <button class="skip-button" data-action="close-payment" bindtap="onTap">暂不解锁</button>
    </view>

    <text class="disclaimer">ⓘ 结果基于当前资料分析，仅供学习参考。</text>
  </scroll-view>

  <view class="payment-mask" wx:if="{{paymentModalVisible}}" catchtouchmove="noop">
    <view class="payment-sheet">
      <view class="sheet-handle"></view>
      <button class="sheet-close" data-action="close-payment" bindtap="onTap">×</button>

      <view class="sheet-head">
        <text class="sheet-title">确认解锁完整报告</text>
        <view class="sheet-price">
          <text class="sheet-price-number">9.9</text>
          <text class="sheet-price-unit">元</text>
        </view>
        <text class="sheet-subtitle">已完成初判，可立即解锁完整提分报告</text>
      </view>

      <view class="benefit-panel">
        <view class="benefit-title">
          <image src="/assets/icons/sparkle-gold.png" mode="aspectFit" />
          <text>支付后可解锁</text>
          <image src="/assets/icons/sparkle-gold.png" mode="aspectFit" />
        </view>
        <view class="benefit-grid">
          <view class="benefit-item">
            <image src="/assets/icons/success-check-green.png" mode="aspectFit" />
            <text>完整报告</text>
          </view>
          <view class="benefit-item">
            <image src="/assets/icons/success-check-green.png" mode="aspectFit" />
            <text>7天行动建议</text>
          </view>
          <view class="benefit-item">
            <image src="/assets/icons/success-check-green.png" mode="aspectFit" />
            <text>详细丢分点分析</text>
          </view>
          <view class="benefit-item">
            <image src="/assets/icons/success-check-green.png" mode="aspectFit" />
            <text>关键错题修复</text>
          </view>
          <view class="benefit-item">
            <image src="/assets/icons/success-check-green.png" mode="aspectFit" />
            <text>优先补弱顺序</text>
          </view>
          <view class="benefit-item">
            <image src="/assets/icons/success-check-green.png" mode="aspectFit" />
            <text>家长学习建议</text>
          </view>
        </view>
      </view>

      <text class="payment-error" wx:if="{{paymentError}}">{{paymentError}}</text>
      <button class="sheet-primary {{paymentLoading ? 'is-loading' : ''}}" data-action="confirm-payment" bindtap="onTap" loading="{{paymentLoading}}">
        {{paymentPrimaryText}}
      </button>
      <button class="sheet-secondary" data-action="close-payment" bindtap="onTap">暂不解锁</button>
    </view>
  </view>
</view>
