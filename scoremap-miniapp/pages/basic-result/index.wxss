page {
  min-height: 100%;
  background: #fbfbff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.basic-result-page {
  width: 390px;
  min-height: 844px;
  overflow: hidden;
  background: linear-gradient(180deg, #fbfbff 0%, #f8f7ff 100%);
  color: #151b3a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.status-bar {
  height: 34px;
  padding: 8px 34px 0;
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
  color: #050816;
  font-size: 12px;
  font-weight: 700;
}

.status-bar text:last-child,
.status-bar span:last-child {
  position: relative;
  width: 38px;
  height: 13px;
  color: transparent;
}

.status-bar text:last-child::before,
.status-bar span:last-child::before {
  content: "";
  position: absolute;
  right: 15px;
  bottom: 2px;
  width: 15px;
  height: 10px;
  background:
    linear-gradient(#111 0 0) left 7px bottom / 2px 3px no-repeat,
    linear-gradient(#111 0 0) left 11px bottom / 2px 5px no-repeat,
    linear-gradient(#111 0 0) left 15px bottom / 2px 7px no-repeat;
}

.status-bar text:last-child::after,
.status-bar span:last-child::after {
  content: "";
  position: absolute;
  right: 0;
  bottom: 1px;
  width: 13px;
  height: 8px;
  border: 1px solid #111;
  border-radius: 2px;
  box-shadow: 3px 2px 0 -1px #111;
  background: linear-gradient(90deg, #111 0 9px, transparent 9px);
}

.top-bar {
  position: relative;
  height: 50px;
  padding: 0 45px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.back-button {
  position: absolute;
  left: 50px;
  top: 6px;
  width: 24px;
  height: 32px;
  color: #111827;
  font-size: 34px;
  line-height: 28px;
}

.page-title {
  color: #111827;
  font-size: 17px;
  font-weight: 900;
}

.page-subtitle {
  position: absolute;
  right: 48px;
  top: 16px;
  color: #1d2450;
  font-size: 10px;
}

.result-scroll {
  height: 760px;
  padding: 0 45px 20px;
  box-sizing: border-box;
}

.hero-card,
.summary-card,
.locked-card,
.upgrade-card {
  width: 300px;
  border-radius: 9px;
  background: #ffffff;
  box-shadow: 0 7px 22px rgba(108, 91, 190, 0.1);
  box-sizing: border-box;
}

.hero-card {
  height: 145px;
  padding: 22px 14px 14px 18px;
  display: flex;
  justify-content: space-between;
  background: linear-gradient(135deg, #f8f6ff 0%, #f2efff 100%);
}

.hero-copy-wrap {
  width: 168px;
}

.hero-title,
.hero-copy,
.success-pill,
.summary-title,
.summary-copy,
.locked-heading,
.locked-row,
.disclaimer {
  display: block;
}

.hero-title {
  color: #172047;
  font-size: 20px;
  font-weight: 900;
  line-height: 24px;
}

.hero-copy {
  margin-top: 9px;
  color: #2d365d;
  font-size: 11px;
  line-height: 18px;
}

.success-pill {
  width: 84px;
  height: 21px;
  margin-top: 13px;
  border-radius: 7px;
  background: #dcfce7;
  color: #059669;
  font-size: 10px;
  line-height: 21px;
  text-align: center;
}

.hero-owl {
  width: 104px;
  height: 110px;
  margin-top: -8px;
}

.summary-card {
  margin-top: 13px;
  padding: 0 14px;
}

.summary-row {
  height: 40px;
  display: grid;
  grid-template-columns: 28px 92px 1fr;
  align-items: center;
  border-bottom: 1px solid #edeafa;
}

.summary-row.no-border {
  border-bottom: 0;
}

.summary-icon {
  width: 23px;
  height: 23px;
  border-radius: 7px;
  color: #7458ff;
  background: #f0ecff;
  font-size: 13px;
  line-height: 23px;
  text-align: center;
  font-weight: 900;
}

.summary-title {
  color: #111827;
  font-size: 12px;
  font-weight: 900;
}

.summary-copy {
  color: #253056;
  font-size: 10px;
  text-align: right;
}

.locked-card {
  margin-top: 12px;
  padding: 12px 14px 7px;
}

.locked-heading {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 7px;
  color: #16204a;
  font-size: 13px;
  font-weight: 900;
}

.locked-heading-icon {
  width: 16px;
  height: 16px;
}

.locked-row {
  height: 25px;
  margin-top: 4px;
  padding: 0 9px;
  border: 1px solid #ece9fb;
  border-radius: 6px;
  display: grid;
  grid-template-columns: 20px 1fr 14px;
  align-items: center;
  color: #9097b4;
  font-size: 10px;
  box-sizing: border-box;
}

.locked-row-icon {
  width: 12px;
  height: 12px;
}

.upgrade-card {
  margin-top: 12px;
  min-height: 178px;
  padding: 18px 12px 13px;
  border: 1px solid #d881ff;
  box-shadow: 0 10px 26px rgba(123, 91, 255, 0.14);
}

.price-lock {
  position: relative;
  float: left;
  width: 56px;
  height: 62px;
}

.price-lock::before {
  content: "";
  position: absolute;
  left: -4px;
  top: -2px;
  width: 58px;
  height: 58px;
  border-radius: 18px;
  background: radial-gradient(circle at 50% 42%, #f4efff 0%, #f8f6ff 60%, transparent 70%);
}

.price-lock-icon {
  position: relative;
  z-index: 1;
  width: 56px;
  height: 56px;
}

.price-line {
  min-height: 58px;
  color: #1a2145;
  font-size: 10px;
  line-height: 20px;
}

.price-line text:first-child {
  color: #6b4cff;
  font-size: 29px;
  font-weight: 900;
  line-height: 32px;
}

.price-line text:nth-child(2) {
  margin: 0 12px 0 2px;
  color: #6b4cff;
  font-size: 13px;
  font-weight: 900;
}

.mini-benefits {
  clear: both;
  height: 22px;
  margin: 4px 0 12px;
  display: flex;
  justify-content: center;
  gap: 23px;
  color: #5f54d9;
  font-size: 10px;
}

.unlock-button {
  width: 274px;
  height: 42px;
  border-radius: 7px;
  background: linear-gradient(180deg, #805cff 0%, #5b3df4 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 900;
  box-shadow: 0 8px 18px rgba(91, 61, 244, 0.22);
}

.skip-button {
  width: 274px;
  height: 28px;
  margin-top: 6px;
  color: #5e47ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 800;
}

.disclaimer {
  margin-top: 11px;
  color: #8c92ad;
  text-align: center;
  font-size: 10px;
}
