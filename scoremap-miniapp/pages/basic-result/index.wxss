page {
  min-height: 100%;
  background: #fbfbff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.basic-result-page {
  width: 390px;
  min-height: 844px;
  overflow: hidden;
  background: linear-gradient(180deg, #fbfbff 0%, #f8f7ff 100%);
  color: #151b3a;
  font-family: "Inter", "Microsoft YaHei UI", "Microsoft YaHei", "PingFang SC", "Noto Sans SC", "DengXian", "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, "Helvetica Neue", Arial, sans-serif;
}

.status-bar {
  height: 24px;
  padding: 6px 34px 0;
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
  color: #050816;
  font-size: 12px;
  font-weight: 700;
}

.status-bar {
  visibility: hidden;
}

.status-bar text:last-child,
.status-bar span:last-child {
  position: relative;
  width: 38px;
  height: 13px;
  color: transparent;
}

.status-bar text:last-child::before,
.status-bar span:last-child::before {
  content: "";
  position: absolute;
  right: 15px;
  bottom: 2px;
  width: 15px;
  height: 10px;
  background:
    linear-gradient(#111 0 0) left 7px bottom / 2px 3px no-repeat,
    linear-gradient(#111 0 0) left 11px bottom / 2px 5px no-repeat,
    linear-gradient(#111 0 0) left 15px bottom / 2px 7px no-repeat;
}

.status-bar text:last-child::after,
.status-bar span:last-child::after {
  content: "";
  position: absolute;
  right: 0;
  bottom: 1px;
  width: 13px;
  height: 8px;
  border: 1px solid #111;
  border-radius: 2px;
  box-shadow: 3px 2px 0 -1px #111;
  background: linear-gradient(90deg, #111 0 9px, transparent 9px);
}

.top-bar {
  position: relative;
  height: 56px;
  padding: 0 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.back-button {
  position: absolute;
  left: 18px;
  top: 11px;
  width: 24px;
  height: 32px;
  color: #111827;
  font-size: 34px;
  line-height: 28px;
}

.page-title {
  color: #111827;
  font-size: 19px;
  font-weight: 700;
}

.page-subtitle {
  position: absolute;
  right: 24px;
  top: 20px;
  color: #1d2450;
  font-size: 10px;
}

.result-scroll {
  height: 764px;
  padding: 0 16px 20px;
  box-sizing: border-box;
}

.hero-card,
.summary-card,
.locked-card,
.upgrade-card {
  width: 358px;
  border-radius: 14px;
  background: #ffffff;
  box-shadow: 0 7px 22px rgba(108, 91, 190, 0.1);
  box-sizing: border-box;
}

.hero-card {
  height: 142px;
  padding: 15px 0 14px 20px;
  display: flex;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #f6f7ff 0%, #eef3ff 100%);
}

.hero-copy-wrap {
  position: relative;
  z-index: 1;
  width: 210px;
}

.hero-title,
.hero-copy,
.success-pill,
.summary-title,
.summary-copy,
.locked-heading,
.locked-row,
.disclaimer {
  display: block;
}

.hero-title {
  color: #172047;
  font-size: 24px;
  font-weight: 700;
  line-height: 29px;
}

.hero-copy {
  margin-top: 6px;
  color: #2d365d;
  font-size: 14px;
  line-height: 20px;
}

.success-pill {
  width: 128px;
  height: 24px;
  margin-top: 9px;
  border-radius: 999px;
  background: #dcfce7;
  color: #059669;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  font-size: 12px;
  text-align: center;
  font-weight: 700;
}

.success-pill-icon {
  width: 14px;
  height: 14px;
}

.hero-owl {
  position: absolute;
  right: 12px;
  bottom: 5px;
  width: 118px;
  height: 118px;
}

.summary-card {
  margin-top: 8px;
  padding: 0 16px;
}

.summary-row {
  min-height: 38px;
  display: grid;
  grid-template-columns: 36px 112px 1fr;
  align-items: center;
  border-bottom: 1px solid #f1f2f6;
}

.summary-row.no-border {
  border-bottom: 0;
}

.summary-icon {
  width: 28px;
  height: 28px;
  border-radius: 10px;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-icon image {
  width: 20px;
  height: 20px;
}

.summary-icon.trend {
  background: #eff6ff;
}

.summary-icon.doc {
  background: #faf5ff;
}

.summary-icon.idea {
  background: #fefce8;
}
.summary-title {
  color: #374151;
  font-size: 13px;
  font-weight: 700;
}

.summary-copy {
  color: #1f2937;
  font-size: 11px;
  text-align: right;
  font-weight: 700;
  line-height: 15px;
  word-break: keep-all;
}

.locked-card {
  margin-top: 8px;
  padding: 9px 16px 9px;
}

.locked-heading {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 3px;
  color: #6366f1;
  font-size: 15px;
  font-weight: 700;
}

.locked-heading-icon {
  width: 16px;
  height: 16px;
}

.locked-row {
  height: 25px;
  margin-top: 4px;
  padding: 0 14px;
  border: 0;
  border-radius: 10px;
  background: #f8f9fb;
  display: grid;
  grid-template-columns: 24px 1fr 18px;
  align-items: center;
  color: #9097b4;
  font-size: 11px;
  line-height: 25px;
  box-sizing: border-box;
}

.locked-row-icon {
  width: 14px;
  height: 14px;
  filter: grayscale(1) brightness(0.74);
}

.upgrade-card {
  margin-top: 12px;
  min-height: 146px;
  padding: 13px 12px 10px;
  border: 1px solid #d881ff;
  box-shadow: 0 10px 26px rgba(123, 91, 255, 0.14);
}

.price-lock {
  position: relative;
  float: left;
  width: 52px;
  height: 54px;
}

.price-lock::before {
  content: "";
  position: absolute;
  left: -4px;
  top: -2px;
  width: 52px;
  height: 52px;
  border-radius: 18px;
  background: radial-gradient(circle at 50% 42%, #f4efff 0%, #f8f6ff 60%, transparent 70%);
}

.price-lock-icon {
  position: relative;
  z-index: 1;
  width: 52px;
  height: 52px;
}

.price-line {
  min-height: 48px;
  color: #1a2145;
  font-size: 10px;
  line-height: 20px;
}

.price-line text:first-child {
  color: #6b4cff;
  font-size: 27px;
  font-weight: 700;
  line-height: 30px;
}

.price-line text:nth-child(2) {
  margin: 0 12px 0 2px;
  color: #6b4cff;
  font-size: 13px;
  font-weight: 700;
}

.mini-benefits {
  clear: both;
  height: 22px;
  margin: 2px 0 9px;
  display: flex;
  justify-content: center;
  gap: 23px;
  color: #5f54d9;
  font-size: 10px;
}

.unlock-button {
  width: 274px;
  height: 38px;
  border-radius: 7px;
  background: linear-gradient(180deg, #805cff 0%, #5b3df4 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 700;
  box-shadow: 0 8px 18px rgba(91, 61, 244, 0.22);
}

.skip-button {
  width: 274px;
  height: 24px;
  margin-top: 4px;
  color: #5e47ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
}

.disclaimer {
  margin-top: 11px;
  color: #8c92ad;
  text-align: center;
  font-size: 10px;
}
