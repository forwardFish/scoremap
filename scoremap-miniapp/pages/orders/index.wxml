<view class="orders-screen">
  <view class="orders-header">
    <text class="orders-title">Order records</text>
    <text class="orders-subtitle">Local payment and report history from the My flow. This page uses the same product shell but has no independent pixel reference.</text>
  </view>

  <view class="orders-summary">
    <view class="summary-item">
      <text class="summary-value">3</text>
      <text class="summary-label">Total records</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <text class="summary-value">2</text>
      <text class="summary-label">Paid items</text>
    </view>
  </view>

  <view class="order-card">
    <image class="order-icon basic" src="/assets/icons/document-blue.png" mode="aspectFit" />
    <view class="order-copy">
      <text class="order-title">1 yuan basic analysis</text>
      <text class="order-meta">Paid with local-wechat-pay-mock</text>
    </view>
    <text class="order-amount">CNY 1</text>
  </view>

  <view class="order-card">
    <image class="order-icon full" src="/assets/icons/report-docs-blue.png" mode="aspectFit" />
    <view class="order-copy">
      <text class="order-title">9.9 full report unlock</text>
      <text class="order-meta">Full AI report and practice support</text>
    </view>
    <text class="order-amount">CNY 9.9</text>
  </view>

  <view class="order-card pending">
    <image class="order-icon pending-dot" src="/assets/icons/history-clock.png" mode="aspectFit" />
    <view class="order-copy">
      <text class="order-title">Preview analysis created</text>
      <text class="order-meta">Waiting for parent to decide whether to unlock</text>
    </view>
    <text class="order-status">Pending</text>
  </view>

  <button class="orders-back" data-action="my" bindtap="onTap">Back to My</button>
</view>
