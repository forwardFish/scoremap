<view class="replica-page {{derived ? 'derived-page' : ''}}">
  <view class="derived-shell fallback-shell">
    <view class="status-spacer"></view>
    <view class="derived-title">{{title}}</view>
    <view class="derived-card" wx:for="{{cards}}" wx:key="*this">{{item}}</view>
  </view>
  <image wx:if="{{!derived && !imageLoadFailed && reference}}" class="reference-image" src="{{reference}}" mode="widthFix" show-menu-by-longpress="false" binderror="onImageError" />
  <button wx:for="{{hotspots}}" wx:key="action" class="hotspot {{item.className}}" data-action="{{item.action}}" bindtap="onTap" aria-label="{{item.label}}"></button>
</view>