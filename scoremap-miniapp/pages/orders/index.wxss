page { min-height: 100%; background: #f8f8ff; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; text-align: left; }
button::after { border: 0; }

.orders-screen {
  min-height: 100vh;
  padding: 64rpx 30rpx 164rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e6e6fa 0%, #f8f8ff 25%, #f8f8ff 100%);
  color: #111827;
}
.orders-header { margin-bottom: 28rpx; }
.orders-title { display: block; font-size: 42rpx; line-height: 1.15; font-weight: 900; }
.orders-subtitle { display: block; margin-top: 14rpx; max-width: 560rpx; font-size: 24rpx; line-height: 1.5; color: #6b7280; }
.orders-summary { height: 144rpx; margin-bottom: 24rpx; border-radius: 34rpx; background: #fff; box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.05); display: flex; align-items: center; }
.summary-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.summary-value { font-size: 42rpx; line-height: 1; font-weight: 900; color: #111827; }
.summary-label { font-size: 24rpx; color: #6b7280; }
.summary-divider { width: 2rpx; height: 72rpx; background: #f3f4f6; }
.order-card { min-height: 112rpx; margin-bottom: 22rpx; padding: 24rpx 26rpx; border-radius: 30rpx; background: #fff; box-shadow: 0 14rpx 34rpx rgba(31, 41, 55, 0.05); display: flex; align-items: center; box-sizing: border-box; }
.order-card.pending { background: #fbfbff; }
.order-icon { width: 72rpx; height: 72rpx; border-radius: 24rpx; margin-right: 22rpx; flex: 0 0 auto; position: relative; }
.order-icon::before { content: ""; position: absolute; left: 20rpx; top: 20rpx; width: 32rpx; height: 32rpx; border-radius: 50%; background: currentColor; }
.order-icon.basic { background: #fff7ed; color: #f59e0b; }
.order-icon.full { background: #f0edff; color: #7c3aed; }
.order-icon.pending-dot { background: #eff6ff; color: #2563eb; }
.order-copy { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }
.order-title { font-size: 29rpx; line-height: 1.3; font-weight: 900; color: #111827; }
.order-meta { font-size: 23rpx; line-height: 1.4; color: #6b7280; }
.order-amount { margin-left: 18rpx; font-size: 30rpx; font-weight: 900; color: #111827; }
.order-status { margin-left: 18rpx; height: 40rpx; padding: 0 16rpx; border-radius: 999rpx; background: #eff6ff; color: #2563eb; display: flex; align-items: center; font-size: 22rpx; font-weight: 800; }
.orders-back { position: fixed; left: 30rpx; right: 30rpx; bottom: 46rpx; height: 92rpx; border-radius: 30rpx; background: #111827; color: #fff; font-size: 30rpx; font-weight: 900; display: flex; align-items: center; justify-content: center; text-align: center; box-shadow: 0 18rpx 34rpx rgba(17, 24, 39, 0.18); }

/* Icon asset replacements */
.order-icon { display: block; object-fit: contain; padding: 8rpx; box-sizing: border-box; }
.order-icon::before { content: none; }
