<view class="preview-page">
  <view class="status-bar">
    <text>9:41</text>
    <text>wifi</text>
  </view>

  <view class="top-bar">
    <button class="back-button" data-action="back" bindtap="onTap">‹</button>
    <text class="page-title">初判报告（预览）</text>
  </view>

  <scroll-view class="preview-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="preview-card soft-blur">
      <view class="card-row">
        <text class="section-title">初步分析结果</text>
        <view class="unlock-pill">
          <image class="pill-icon" src="/assets/icons/lock-purple.png" mode="aspectFit" />
          <text>完整内容需解锁</text>
        </view>
      </view>
      <view class="skeleton skeleton-lg"></view>
      <view class="skeleton skeleton-md"></view>
      <view class="skeleton skeleton-sm"></view>
      <view class="skeleton skeleton-wide"></view>
      <view class="divider"></view>
      <text class="section-title spaced">主要问题（部分）</text>
      <view class="bullet-row"><view class="dot"></view><text>二元一次方程应用题理解不足</text></view>
      <view class="bullet-row"><view class="dot"></view><text>一次函数图像移动规律易错</text></view>
      <view class="divider"></view>
      <text class="section-title spaced">优先建议（部分）</text>
      <view class="bullet-row"><view class="dot"></view><text>先补强：行程问题中的数量关系建模</text></view>
      <view class="bullet-row"><view class="dot"></view><text>7 天行动方向：每天 20 分钟专项练习</text></view>
    </view>
  </scroll-view>

  <view class="payment-mask">
    <view class="payment-sheet">
      <view class="sheet-handle"></view>
      <button class="sheet-close" data-action="close-pay" bindtap="onTap">×</button>
      <view class="sheet-title-row">
        <image class="sheet-lock" src="/assets/icons/lock-purple.png" mode="aspectFit" />
        <text>解锁完整初判</text>
      </view>
      <view class="price-row"><text>1.00</text><text>元</text></view>
      <view class="sheet-divider"></view>
      <text class="unlock-heading">支付后可解锁</text>
      <view class="benefit-line"><view class="dot"></view><text>完整初判结果</text></view>
      <view class="benefit-line"><view class="dot"></view><text>主要丢分点分析</text></view>
      <view class="benefit-line"><view class="dot"></view><text>优先补弱建议</text></view>
      <button class="pay-button" loading="{{paying}}" data-action="confirm-pay" bindtap="onTap">立即支付 1 元</button>
    </view>
  </view>

  <view wx:if="{{errorText}}" class="error-text">{{errorText}}</view>
</view>
