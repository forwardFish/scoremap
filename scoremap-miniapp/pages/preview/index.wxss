page { min-height: 100%; background: #f8f9ff; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; }
button::after { border: 0; }

.preview-screen {
  min-height: 100vh;
  background: #f8f9ff;
  color: #1f2937;
  box-sizing: border-box;
  padding-bottom: 190rpx;
}

.preview-shell {
  padding: 44rpx 34rpx 36rpx;
  box-sizing: border-box;
}

.preview-header {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.preview-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.preview-mascot {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(124, 77, 255, 0.12);
}

.preview-mascot-face {
  width: 36rpx;
  height: 30rpx;
  border-radius: 10rpx;
  background: #7c4dff;
  position: relative;
}

.preview-mascot-face::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: -9rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #7c4dff;
}

.preview-eye {
  position: absolute;
  top: 12rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #fff;
}

.preview-eye.left { left: 10rpx; }
.preview-eye.right { right: 10rpx; }

.preview-title {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.preview-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #10b981;
  font-size: 22rpx;
  font-weight: 800;
}

.preview-hero {
  margin-top: 38rpx;
  min-height: 238rpx;
  border-radius: 42rpx;
  background: #fff;
  box-shadow: 0 20rpx 58rpx rgba(124, 77, 255, 0.08);
  padding: 38rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  overflow: hidden;
  position: relative;
}

.preview-hero::before {
  content: "";
  position: absolute;
  right: -70rpx;
  top: -70rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: #f0e6ff;
}

.preview-hero-copy {
  width: 66%;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  position: relative;
  z-index: 2;
}

.preview-kicker {
  color: #7c4dff;
  font-size: 24rpx;
  font-weight: 800;
}

.preview-headline {
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.preview-summary {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.55;
}

.preview-hero-figure {
  position: absolute;
  right: 26rpx;
  bottom: 18rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #eadbff, #cdb8ff);
  box-shadow: 0 18rpx 36rpx rgba(124, 77, 255, 0.14);
}

.preview-hero-figure::before {
  content: "";
  position: absolute;
  left: 38rpx;
  top: 38rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #b388ff;
}

.preview-cap {
  position: absolute;
  right: 22rpx;
  top: 24rpx;
  width: 68rpx;
  height: 26rpx;
  border-radius: 5rpx;
  background: #1f2937;
  transform: rotate(16deg);
  z-index: 3;
}

.preview-glasses {
  position: absolute;
  left: 46rpx;
  top: 78rpx;
  display: flex;
  gap: 10rpx;
  z-index: 4;
}

.preview-glasses view {
  width: 24rpx;
  height: 16rpx;
  border: 5rpx solid #1f2937;
  border-radius: 12rpx;
}

.preview-section-title {
  margin: 40rpx 4rpx 18rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #111827;
}

.preview-list {
  border-radius: 38rpx;
  background: #fff;
  box-shadow: 0 18rpx 52rpx rgba(31, 41, 55, 0.06);
  padding: 10rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.preview-module,
.locked-row {
  min-height: 116rpx;
  padding: 22rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #f3f4f6;
}

.preview-module:last-child,
.locked-row:last-child { border-bottom: 0; }

.module-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  margin-right: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.module-icon.red { background: #fef2f2; color: #ef4444; }
.module-icon.green { background: #ecfdf5; color: #10b981; }
.module-icon.purple { background: #f3e8ff; color: #7c3aed; }
.module-icon.blue { background: #eff6ff; color: #2563eb; }
.module-icon.amber { background: #fffbeb; color: #f59e0b; }

.module-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.module-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.module-desc {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.35;
}

.module-arrow {
  color: #c4c9d4;
  font-size: 50rpx;
  line-height: 1;
}

.preview-locked {
  min-height: 236rpx;
  position: relative;
}

.preview-locked .locked-row {
  opacity: 0.42;
}

.preview-locked .locked-row.dim {
  opacity: 0.28;
  padding-bottom: 60rpx;
}

.lock-dot::before {
  content: "";
  width: 24rpx;
  height: 18rpx;
  border: 5rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.locked-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 172rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.96) 58%, #fff 100%);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 26rpx;
  box-sizing: border-box;
}

.lock-badge {
  min-height: 58rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.lock-shape {
  width: 20rpx;
  height: 16rpx;
  border: 4rpx solid #6b7280;
  border-radius: 4rpx;
  position: relative;
}

.lock-shape::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: -16rpx;
  width: 10rpx;
  height: 14rpx;
  border: 4rpx solid #6b7280;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
}

.preview-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 26rpx 34rpx 42rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -16rpx 42rpx rgba(31, 41, 55, 0.06);
  box-sizing: border-box;
}

.preview-pay {
  width: 100%;
  height: 98rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8e6dfe 0%, #714afe 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 32rpx rgba(124, 77, 255, 0.26);
}

.preview-footnote {
  display: block;
  margin-top: 16rpx;
  color: #7c4dff;
  font-size: 23rpx;
  font-weight: 700;
  text-align: center;
}
