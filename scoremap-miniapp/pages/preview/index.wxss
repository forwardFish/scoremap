page {
  min-height: 100%;
  background: linear-gradient(180deg, #fbfbff 0%, #f7f5ff 100%);
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.preview-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  overflow: hidden;
  background: #ffffff;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.status-bar {
  height: 34px;
  padding: 8px 34px 0 72px;
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
  color: rgba(17, 24, 39, 0.1);
  font-size: 12px;
  font-weight: 700;
}

.top-bar {
  height: 50px;
  padding: 0 30px 0 58px;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.back-button {
  position: absolute;
  left: 58px;
  top: 45px;
  width: 24px;
  height: 32px;
  color: #111827;
  font-size: 34px;
  line-height: 28px;
}

.page-title {
  flex: 1;
  text-align: center;
  color: #111827;
  font-size: 16px;
  font-weight: 900;
}

.preview-scroll {
  height: 560px;
  padding: 0 0 170px;
  box-sizing: border-box;
}

.preview-card {
  width: 276px;
  min-height: 474px;
  margin: 5px 0 0 58px;
  padding: 22px 16px 24px;
  border-radius: 10px;
  background: rgba(241, 239, 255, 0.88);
  box-sizing: border-box;
}

.soft-blur {
  filter: blur(3px);
  opacity: 0.72;
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  color: #11193a;
  font-size: 15px;
  font-weight: 700;
}

.unlock-pill {
  height: 20px;
  padding: 0 8px;
  border-radius: 8px;
  background: #edeaff;
  color: #5d56f3;
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 8px;
}

.floating-pay-button {
  position: absolute;
  left: 34px;
  right: 34px;
  bottom: 56px;
  z-index: 2;
  height: 60px;
  border-radius: 16px;
  background: linear-gradient(180deg, #815cff 0%, #5b3df4 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 900;
  box-shadow: 0 8px 18px rgba(91, 61, 244, 0.22);
}

.pill-icon {
  width: 10px;
  height: 10px;
}

.skeleton {
  height: 11px;
  margin-top: 10px;
  border-radius: 6px;
  background: #e5e3f3;
}

.skeleton-lg {
  width: 178px;
  margin-top: 18px;
}

.skeleton-md {
  width: 146px;
}

.skeleton-sm {
  width: 116px;
}

.skeleton-wide {
  width: 240px;
  margin-top: 14px;
}

.divider {
  height: 1px;
  margin: 18px 0;
  background: #ddd9ee;
}

.spaced {
  display: block;
  margin-bottom: 18px;
}

.bullet-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 15px;
  color: #1f2a44;
  font-size: 11px;
  line-height: 18px;
}

.dot,
.bullet-row .dot,
.benefit-line .dot {
  flex: 0 0 auto;
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: #e7e3ff;
  box-shadow: inset 0 0 0 3px #f4f1ff;
}

.payment-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10;
  background: rgba(0, 0, 0, 0.48);
  backdrop-filter: blur(5px);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.payment-sheet {
  position: relative;
  width: 390px;
  height: 428px;
  margin-bottom: 0;
  padding: 48px 34px 26px;
  border-radius: 24px 24px 0 0;
  background: #ffffff;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.sheet-handle {
  position: absolute;
  top: 12px;
  left: 176px;
  width: 40px;
  height: 4px;
  border-radius: 4px;
  background: #e5e7eb;
}

.sheet-close {
  position: absolute;
  right: 21px;
  top: 25px;
  width: 32px;
  height: 32px;
  color: #9ca3af;
  font-size: 32px;
  line-height: 28px;
}

.sheet-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: #10152f;
  font-size: 24px;
  font-weight: 900;
}

.sheet-lock {
  width: 42px;
  height: 42px;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-sizing: border-box;
}

.price-row {
  margin-top: 14px;
  color: #6254ff;
  text-align: center;
  font-weight: 900;
}

.price-row text:first-child {
  font-size: 50px;
  line-height: 52px;
}

.price-row text:last-child {
  margin-left: 6px;
  font-size: 18px;
}

.sheet-divider {
  height: 1px;
  margin: 18px 0 16px;
  border-top: 1px dashed #e5e7eb;
  background: transparent;
}

.unlock-heading {
  display: block;
  width: 274px;
  margin: 0 auto;
  text-align: left;
  color: #11193a;
  font-size: 18px;
  font-weight: 800;
}

.benefit-line {
  display: flex;
  align-items: center;
  gap: 14px;
  width: 274px;
  margin: 11px auto 0;
  color: #19213c;
  font-size: 16px;
  line-height: 22px;
}

.benefit-line .dot {
  width: 10px;
  height: 10px;
  background: #c6c4dc;
  box-shadow: none;
}

.pay-button {
  width: 322px;
  height: 60px;
  margin: 24px auto 0;
  border-radius: 16px;
  background: linear-gradient(180deg, #815cff 0%, #5b3df4 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 900;
  box-shadow: 0 8px 18px rgba(91, 61, 244, 0.22);
}

.error-text {
  position: absolute;
  left: 40px;
  right: 40px;
  bottom: 94px;
  color: #b42318;
  font-size: 13px;
  text-align: center;
}
