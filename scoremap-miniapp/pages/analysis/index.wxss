page {
  min-height: 100%;
  background: #f6f4ff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  font: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

.analysis-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  overflow: hidden;
  background: linear-gradient(135deg, #f2f0ff 0%, #fbfdff 100%);
  color: #111c3b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  padding: 28px 20px 0;
}

.analysis-header {
  height: 48px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.back-button {
  width: 28px;
  height: 44px;
  color: #2d2364;
  font-size: 38px;
  line-height: 38px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.robot-icon {
  width: 32px;
  height: 32px;
  border-radius: 16px;
  overflow: hidden;
  background: #111827;
  box-shadow: 0 4px 12px rgba(17, 24, 39, 0.16);
}

.robot-icon image {
  width: 100%;
  height: 100%;
}

.avatar-drawn {
  display: none;
}

.brand-title {
  color: #101946;
  font-size: 22px;
  line-height: 32px;
  font-weight: 900;
}

.analysis-card {
  position: relative;
  height: 625px;
  margin-top: 20px;
  padding: 32px 24px 0;
  border-radius: 24px;
  background: linear-gradient(180deg, #ffffff 0%, #fdfcff 100%);
  box-shadow: 0 10px 35px rgba(123, 97, 255, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.card-glow {
  position: absolute;
  left: 58px;
  top: 58px;
  width: 234px;
  height: 234px;
  border-radius: 117px;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.14), rgba(255, 255, 255, 0) 72%);
}

.analysis-title {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  color: #101946;
  font-size: 30px;
  line-height: 42px;
  font-weight: 900;
}

.analysis-title text {
  color: #8b5cf6;
}

.spark {
  position: absolute;
  z-index: 1;
  color: #c4a7ff;
  font-size: 20px;
}

.sparkle-one {
  left: 69px;
  top: 57px;
}

.sparkle-two {
  right: 82px;
  top: 69px;
}

.sparkle-three {
  right: 62px;
  top: 84px;
  color: #f2c45e;
  font-size: 14px;
}

.progress-stage {
  position: relative;
  height: 265px;
}

.progress-ring {
  position: absolute;
  left: 58px;
  top: 29px;
  width: 190px;
  height: 190px;
}

.ring-track,
.ring-arc {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  box-sizing: border-box;
}

.ring-track {
  border: 15px solid #eeeaff;
}

.ring-arc {
  border: 15px solid transparent;
  border-top-color: #8e6bff;
  border-right-color: #8e6bff;
}

.arc-top {
  transform: rotate(14deg);
}

.arc-bottom {
  border-top-color: transparent;
  border-right-color: transparent;
  border-bottom-color: #8e6bff;
  border-left-color: #8e6bff;
  transform: rotate(-25deg);
}

.ring-center {
  position: absolute;
  inset: 34px;
  border-radius: 54px;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-number {
  color: #8b5cf6;
  font-size: 54px;
  line-height: 60px;
  font-weight: 900;
}

.percent {
  margin-left: 2px;
  margin-top: 16px;
  color: #8b5cf6;
  font-size: 20px;
  font-weight: 900;
}

.owl {
  position: absolute;
  right: 18px;
  top: 148px;
  width: 96px;
  height: 108px;
}

.owl-drawn {
  display: none;
}

.step-list {
  position: relative;
  z-index: 1;
  margin: 0 12px;
}

.step-row {
  position: relative;
  height: 49px;
  margin-bottom: 0;
  padding: 0 14px;
  border-radius: 12px;
  background: #ffffff;
  box-shadow: 0 5px 18px rgba(65, 54, 128, 0.06);
  display: flex;
  align-items: center;
  gap: 10px;
  color: #14203f;
  font-size: 14px;
  font-weight: 600;
  box-sizing: border-box;
}

.step-row::after {
  content: "";
  position: absolute;
  left: 22px;
  bottom: -8px;
  width: 2px;
  height: 10px;
  border-left: 2px dotted #d6d4ff;
}

.step-row:last-child::after {
  display: none;
}

.step-node {
  width: 24px;
  height: 24px;
  border-radius: 12px;
  background: #64c992;
  color: #ffffff;
  font-size: 15px;
  line-height: 24px;
  text-align: center;
  font-weight: 900;
}

.active .step-node {
  background: #f3efff;
  border: 2px dotted #8b5cf6;
  box-sizing: border-box;
}

.pending .step-node {
  background: #eee9ff;
  color: #8b5cf6;
  font-size: 13px;
}

.pending {
  color: #8a91a4;
  font-weight: 500;
}

.estimate {
  height: 28px;
  margin-top: 23px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  color: #8c93a4;
  font-size: 12px;
}

.clock {
  color: #a4aabd;
  font-size: 16px;
}

.primary-button {
  position: absolute;
  left: 28px;
  top: 745px;
  width: 334px;
  height: 60px;
  border-radius: 30px;
  background: linear-gradient(90deg, #a687ff 0%, #7b61ff 100%);
  color: #ffffff;
  font-size: 20px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 7px 18px rgba(123, 97, 255, 0.22);
}

.refresh-button {
  position: absolute;
  left: 130px;
  top: 819px;
  width: 130px;
  height: 34px;
  color: #8b5cf6;
  font-size: 15px;
  font-weight: 700;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

body[data-screen="analysis"] .robot-icon {
  background: #f1f5f9;
  box-shadow: none;
}

body[data-screen="analysis"] .robot-icon image {
  display: block;
}

body[data-screen="analysis"] .avatar-drawn {
  display: none;
}

.owl {
  display: none;
}

.owl-drawn {
  position: absolute;
  right: 28px;
  top: 145px;
  display: block;
  width: 84px;
  height: 94px;
  filter: drop-shadow(0 4px 5px rgba(87, 61, 30, 0.18));
}

.owl-drawn::before {
  content: "";
  position: absolute;
  left: -8px;
  top: -2px;
  width: 92px;
  height: 92px;
  border-radius: 2px;
  background: #ffffff;
  box-shadow: 0 2px 5px rgba(31, 41, 55, 0.08);
  z-index: 0;
}

.owl-ear {
  position: absolute;
  top: 9px;
  width: 24px;
  height: 24px;
  background: #5a2f16;
  transform: rotate(45deg);
  z-index: 1;
}

.owl-ear.left {
  left: 12px;
}

.owl-ear.right {
  right: 12px;
}

.owl-head {
  position: absolute;
  left: 7px;
  top: 15px;
  width: 70px;
  height: 64px;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 54%, #f3d79f 0 25px, #8a4f24 26px, #2f1a12 35px);
  border: 2px solid #3c2418;
  box-sizing: border-box;
  z-index: 2;
}

.owl-body {
  position: absolute;
  left: 15px;
  top: 54px;
  width: 54px;
  height: 39px;
  border-radius: 50% 50% 46% 46%;
  background: linear-gradient(180deg, #6e3f20 0%, #412416 100%);
  z-index: 1;
}

.owl-belly {
  position: absolute;
  left: 11px;
  top: 6px;
  width: 32px;
  height: 28px;
  border-radius: 50%;
  background: #f4e4c7;
}

.owl-eye {
  position: absolute;
  top: 20px;
  width: 21px;
  height: 21px;
  border-radius: 50%;
  background: #f4c742;
  border: 3px solid #3f2619;
  box-sizing: border-box;
  z-index: 3;
}

.owl-eye.left {
  left: 13px;
}

.owl-eye.right {
  right: 13px;
}

.owl-eye view {
  position: absolute;
  left: 5px;
  top: 5px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #111827;
}

.owl-beak {
  position: absolute;
  left: 30px;
  top: 39px;
  width: 10px;
  height: 10px;
  background: #e7a725;
  transform: rotate(45deg);
  z-index: 3;
}

.owl-feather {
  position: absolute;
  left: 22px;
  top: 47px;
  width: 26px;
  height: 12px;
  border-radius: 0 0 18px 18px;
  border-bottom: 3px solid rgba(70, 39, 22, 0.45);
  z-index: 3;
}
