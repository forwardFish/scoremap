page {
  min-height: 100%;
  background: #f6f4ff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  font: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

.analysis-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f2f0ff 0%, #fbfdff 100%);
  color: #162033;
  box-sizing: border-box;
}

.analysis-shell {
  min-height: 100vh;
  padding: 38rpx 30rpx 52rpx;
  box-sizing: border-box;
}

.analysis-header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-button {
  width: 54rpx;
  height: 54rpx;
  position: relative;
}

.back-button::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 12rpx;
  width: 22rpx;
  height: 22rpx;
  border-left: 6rpx solid #111827;
  border-bottom: 6rpx solid #111827;
  transform: rotate(45deg);
  border-radius: 3rpx;
}

.analysis-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bot-mark {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 22rpx rgba(112, 81, 220, 0.16);
}

.bot-face {
  width: 38rpx;
  height: 32rpx;
  border-radius: 10rpx;
  background: #8b5cf6;
  position: relative;
}

.bot-face::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: -10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #8b5cf6;
}

.bot-eye {
  position: absolute;
  top: 12rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #fff;
}

.bot-eye.left {
  left: 10rpx;
}

.bot-eye.right {
  right: 10rpx;
}

.brand-title {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 0;
}

.header-spacer {
  width: 54rpx;
}

.analysis-card {
  margin-top: 42rpx;
  min-height: 1138rpx;
  border-radius: 42rpx;
  background: #fff;
  box-shadow: 0 22rpx 62rpx rgba(123, 96, 217, 0.1);
  padding: 74rpx 62rpx 64rpx;
  box-sizing: border-box;
  position: relative;
}

.card-stars {
  position: absolute;
  left: 0;
  right: 0;
  top: 78rpx;
  height: 72rpx;
  pointer-events: none;
}

.star {
  position: absolute;
  font-size: 30rpx;
  line-height: 1;
}

.star-one {
  left: 70rpx;
  color: #fde56d;
}

.star-two {
  left: 132rpx;
  top: 42rpx;
  color: #d9bcff;
}

.star-three {
  right: 74rpx;
  top: 14rpx;
  color: #fde56d;
}

.star-four {
  right: 30rpx;
  top: 58rpx;
  color: #dec7ff;
}

.analysis-title-row {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  position: relative;
  z-index: 2;
}

.analysis-title-accent,
.analysis-title-text {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.analysis-title-accent {
  color: #8b5cf6;
  font-size: 58rpx;
}

.progress-wrap {
  width: 362rpx;
  height: 362rpx;
  margin: 56rpx auto 82rpx;
  position: relative;
}

.progress-track,
.progress-arc {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  box-sizing: border-box;
}

.progress-track {
  border: 34rpx solid #f0e3ff;
}

.progress-arc {
  border: 34rpx solid transparent;
}

.arc-main {
  border-top-color: #8b5cf6;
  border-right-color: #8b5cf6;
  border-bottom-color: #8b5cf6;
  transform: rotate(20deg);
}

.arc-tail {
  border-left-color: #8b5cf6;
  transform: rotate(-42deg);
}

.progress-value {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-number {
  color: #8b5cf6;
  font-size: 78rpx;
  font-weight: 900;
  line-height: 1;
}

.progress-unit {
  margin-left: 8rpx;
  color: #8b5cf6;
  font-size: 36rpx;
  font-weight: 900;
}

.mascot-bubble {
  position: absolute;
  right: -74rpx;
  bottom: -34rpx;
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ead6ff, #d8baff);
  box-shadow: 0 18rpx 34rpx rgba(148, 113, 246, 0.18);
}

.mascot-bubble::before {
  content: "";
  position: absolute;
  left: 36rpx;
  top: 36rpx;
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #caa4ff;
}

.cap {
  position: absolute;
  right: 18rpx;
  top: 20rpx;
  width: 66rpx;
  height: 26rpx;
  border-radius: 5rpx;
  background: #1f2937;
  transform: rotate(16deg);
  z-index: 2;
}

.glasses {
  position: absolute;
  left: 42rpx;
  top: 72rpx;
  display: flex;
  gap: 10rpx;
  z-index: 3;
}

.glasses view {
  width: 26rpx;
  height: 18rpx;
  border: 6rpx solid #1f2937;
  border-radius: 12rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-row {
  min-height: 84rpx;
  border-radius: 22rpx;
  background: #fbfcff;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  box-sizing: border-box;
  position: relative;
  color: #172033;
  font-size: 28rpx;
  font-weight: 600;
}

.step-row::before {
  content: "";
  position: absolute;
  left: 40rpx;
  top: 70rpx;
  width: 5rpx;
  height: 38rpx;
  background-image: linear-gradient(to bottom, #d8b4fe 50%, transparent 50%);
  background-size: 100% 12rpx;
}

.step-row.pending::before {
  display: none;
}

.step-dot {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  z-index: 2;
}

.done .step-dot {
  background: #34d399;
}

.active .step-dot {
  border: 7rpx dashed #a78bfa;
  background: #fff;
}

.pulse-dot::after {
  content: "";
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #8b5cf6;
}

.pending {
  color: #64748b;
}

.pending .step-dot {
  background: #f3efff;
  color: #a78bfa;
}

.hourglass::before {
  content: "";
  width: 14rpx;
  height: 18rpx;
  border-top: 5rpx solid #a78bfa;
  border-bottom: 5rpx solid #a78bfa;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
}

.estimate-line {
  margin-top: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #64748b;
  font-size: 24rpx;
}

.clock-icon {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 4rpx solid #64748b;
  position: relative;
}

.clock-icon::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 4rpx;
  height: 8rpx;
  border-radius: 3rpx;
  background: #64748b;
}

.clock-icon::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 10rpx;
  width: 8rpx;
  height: 4rpx;
  border-radius: 3rpx;
  background: #64748b;
}

.analysis-actions {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.later-button {
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #a78bfa 0%, #7c3aed 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  box-shadow: 0 18rpx 28rpx rgba(124, 58, 237, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresh-button {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #8b5cf6;
  font-size: 26rpx;
  font-weight: 700;
}

.refresh-icon {
  font-size: 34rpx;
  line-height: 1;
}
