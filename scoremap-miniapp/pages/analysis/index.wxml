<view class="analysis-page">
  <view class="analysis-header">
    <button class="back-button" data-action="back" bindtap="onTap" aria-label="返回">
      <text>‹</text>
    </button>
    <view class="robot-icon">
      <image src="/assets/icons/analysis-robot.png" mode="aspectFit" />
    </view>
    <text class="brand-title">AI 提分决策</text>
  </view>

  <view class="analysis-card">
    <view class="card-glow"></view>
    <text class="spark sparkle-one">✦</text>
    <text class="spark sparkle-two">✦</text>
    <text class="spark sparkle-three">✦</text>

    <text class="analysis-title"><text>AI</text> 正在分析中</text>

    <view class="progress-stage">
      <view class="progress-ring">
        <view class="ring-track"></view>
        <view class="ring-arc arc-top"></view>
        <view class="ring-arc arc-bottom"></view>
        <view class="ring-center">
          <text class="progress-number">{{progress}}</text>
          <text class="percent">%</text>
        </view>
      </view>
      <image class="owl" src="/assets/icons/analysis-teacher-pointer.png" mode="aspectFit" />
    </view>

    <view class="step-list">
      <view class="step-row {{item.status}}" wx:for="{{steps}}" wx:key="id">
        <view class="step-node {{item.nodeClass}}">
          <image wx:if="{{item.nodeIcon}}" src="{{item.nodeIcon}}" mode="aspectFit" />
        </view>
        <text>{{item.text}}</text>
      </view>
    </view>

    <view class="estimate">
      <image class="clock-icon" src="/assets/icons/analysis-clock.png" mode="aspectFit" />
      <text>{{estimateText}}</text>
    </view>
  </view>

  <button class="primary-button" data-action="later" bindtap="onTap">稍后查看</button>
  <button class="refresh-button {{refreshing ? 'refreshing' : ''}}" data-action="refresh" bindtap="onTap">
    <image class="refresh-icon" src="/assets/icons/analysis-refresh.png" mode="aspectFit" />
    <text>{{refreshing ? '刷新中' : '刷新进度'}}</text>
  </button>
  <text class="analysis-toast" wx:if="{{toast}}">{{toast}}</text>
</view>
