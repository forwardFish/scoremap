<view class="analysis-page">
  <view class="analysis-header">
    <button class="back-button" data-action="later" bindtap="onTap" aria-label="返回">
      <text>‹</text>
    </button>
    <image class="robot-icon" src="/assets/icons/ai-robot-smile.png" mode="aspectFit" />
    <text class="brand-title">AI 提分决策</text>
  </view>

  <view class="analysis-card">
    <view class="card-glow"></view>
    <text class="spark sparkle-one">✦</text>
    <text class="spark sparkle-two">✦</text>
    <text class="spark sparkle-three">✦</text>

    <text class="analysis-title"><text>AI</text> 正在分析中</text>

    <view class="progress-stage">
      <view class="progress-ring">
        <view class="ring-track"></view>
        <view class="ring-arc arc-top"></view>
        <view class="ring-arc arc-bottom"></view>
        <view class="ring-center">
          <text class="progress-number">68</text>
          <text class="percent">%</text>
        </view>
      </view>
      <image class="owl" src="/assets/icons/owl-report-teacher.png" mode="aspectFit" />
    </view>

    <view class="step-list">
      <view class="step-row done">
        <view class="step-node">✓</view>
        <text>已识别上传资料</text>
      </view>
      <view class="step-row done">
        <view class="step-node">✓</view>
        <text>已匹配年级与学科</text>
      </view>
      <view class="step-row active">
        <view class="step-node spinner"></view>
        <text>正在定位主要丢分点</text>
      </view>
      <view class="step-row pending">
        <view class="step-node hourglass">⌛</view>
        <text>正在生成初步建议</text>
      </view>
    </view>

    <view class="estimate">
      <text class="clock">◷</text>
      <text>通常需要 20-30秒</text>
    </view>
  </view>

  <button class="primary-button" data-action="later" bindtap="onTap">稍后查看</button>
  <button class="refresh-button" data-action="refresh" bindtap="onTap">↻ 刷新进度</button>
</view>
