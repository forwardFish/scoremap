@import "../ai-tutor/c13-common.wxss";

.generated {
  height: 51px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3e4558;
  font-size: 13px;
}

.exercise-card {
  position: relative;
  margin: 12px 16px 0;
  padding: 25px 24px 30px;
  border-radius: 18px;
  background: #ffffff;
  box-shadow: 0 6px 18px rgba(82, 69, 135, 0.06);
  overflow: hidden;
}

.exercise-head {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  color: #6b4ee6;
}

.exercise-head image {
  width: 28px;
  height: 28px;
}

.exercise-title {
  display: block;
  font-size: 18px;
  line-height: 25px;
  font-weight: 900;
}

.title-underline {
  width: 50px;
  height: 4px;
  margin: 8px auto 0;
  border-radius: 2px;
  background: #b8a6ff;
}

.star {
  position: absolute;
  right: 29px;
  top: 8px;
  color: #e8e1ff;
  font-size: 88px;
}

.stem {
  display: block;
  margin-top: 32px;
  color: #1e2439;
  font-size: 15px;
  line-height: 24px;
}

.options {
  margin-top: 25px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.option-row {
  height: 60px;
  padding: 0 18px;
  border-radius: 10px;
  background: #f3edf9;
  color: #1d2238;
  font-size: 15px;
  display: flex;
  align-items: center;
  gap: 18px;
}

.option-label {
  width: 32px;
  height: 32px;
  border-radius: 16px;
  background: #fbf8ff;
  color: #6b4ee6;
  text-align: center;
  line-height: 32px;
  font-size: 13px;
  font-weight: 900;
}

.submit-button {
  margin-top: 30px;
  width: 100%;
  height: 56px;
  border-radius: 28px;
  background: #6b4ee6;
  color: #ffffff;
  font-size: 16px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 18px rgba(107, 78, 230, 0.25);
}

.history-card {
  margin: 16px;
  height: 64px;
  padding: 0 16px;
  border-radius: 10px;
  background: #ffffff;
  box-shadow: 0 6px 18px rgba(82, 69, 135, 0.06);
  color: #1e2439;
  font-size: 14px;
  font-weight: 800;
  display: flex;
  align-items: center;
}
