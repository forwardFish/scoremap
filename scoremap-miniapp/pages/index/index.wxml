<view class="home-page">
  <view class="home-header">
    <view class="brand">
      <view class="brand-icon-wrap">
        <image class="brand-icon" src="/assets/icons/ai-robot-smile.png" mode="aspectFit" />
      </view>
      <text class="brand-title">AI 提分决策</text>
    </view>
    <button class="icon-button" data-action="reports" bindtap="onTap" aria-label="消息">
      <image class="chat-icon" src="/assets/icons/chat-bubble.png" mode="aspectFit" />
    </button>
  </view>

  <scroll-view class="home-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="hero-card">
      <view class="hero-glow"></view>
      <view class="hero-top">
        <view class="hero-copy">
          <text class="hero-title">上传孩子资料，</text>
          <text class="hero-title"><text class="hero-ai">AI</text> 帮你看清先补什么</text>
          <view class="hero-subtitle">
            <text>支持试卷 / 错题 / 成绩单，先做</text>
            <text class="price-highlight">1 元</text>
            <text>初判</text>
          </view>
        </view>
        <view class="hero-owl" aria-hidden="true">
          <image class="hero-owl-image" src="/assets/icons/owl-study-stack.png" mode="aspectFit" />
        </view>
      </view>

      <view class="upload-panel">
        <view class="upload-asset" aria-hidden="true">
          <image class="upload-asset-image" src="/assets/icons/upload-folder.png" mode="aspectFit" />
        </view>
        <view class="upload-copy">
          <text class="upload-hint">支持图片 / PDF</text>
          <button class="upload-button" data-action="upload" bindtap="onTap">
            <text class="upload-button-icon">☁</text>
            <text>上传资料</text>
          </button>
        </view>
      </view>
    </view>

    <view class="quick-actions">
      <button class="quick-card" data-action="sample" bindtap="onTap">
        <view class="quick-icon sample-icon">
          <image class="quick-icon-image" src="/assets/icons/document-list-purple.png" mode="aspectFit" />
        </view>
        <text class="quick-label">查看样例</text>
        <text class="quick-chevron">›</text>
      </button>
      <button class="quick-card" data-action="reports" bindtap="onTap">
        <view class="quick-icon reports-icon">
          <image class="quick-icon-image" src="/assets/icons/document-blue.png" mode="aspectFit" />
        </view>
        <text class="quick-label">我的报告</text>
        <text class="quick-chevron reports-chevron">›</text>
      </button>
    </view>

    <view class="recent-card">
      <view class="section-head">
        <text class="section-title">最近报告</text>
        <button class="more-link" data-action="reports" bindtap="onTap">
          <text>查看更多</text>
          <text class="more-chevron">›</text>
        </button>
      </view>

      <button class="report-row" data-action="reports" bindtap="onTap">
        <view class="report-leading math-icon">
          <image src="/assets/icons/report-chart-clipboard.png" mode="aspectFit" />
        </view>
        <text class="report-title">初一数学月考</text>
        <view class="report-status status-done">
          <text>AI 初判已完成</text>
        </view>
        <text class="row-chevron">›</text>
      </button>

      <view class="row-divider"></view>

      <button class="report-row" data-action="reports" bindtap="onTap">
        <view class="report-leading error-icon">
          <image src="/assets/icons/error-x-eraser.png" mode="aspectFit" />
          <view class="error-dot"></view>
        </view>
        <text class="report-title">错题专项分析</text>
        <view class="report-status status-pending">
          <text>待查看结果</text>
        </view>
        <text class="row-chevron">›</text>
      </button>
    </view>
  </scroll-view>

  <view class="bottom-tabs">
    <button class="tab-item active" data-action="home" bindtap="onTap">
      <image class="tab-icon" src="/assets/icons/home-purple.png" mode="aspectFit" />
      <text>首页</text>
    </button>
    <button class="tab-item" data-action="my" bindtap="onTap">
      <image class="tab-icon" src="/assets/icons/user-avatar-gray.png" mode="aspectFit" />
      <text>我的</text>
    </button>
  </view>
</view>
