page {
  min-height: 100%;
  background: #f8f9fe;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: inherit;
  text-align: left;
}

button::after {
  border: 0;
}

.home-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  overflow: hidden;
  background: linear-gradient(180deg, #f3f0ff 0%, #f8f9fe 39%, #f8f9fe 100%);
  color: #333333;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.home-header {
  height: 68px;
  padding: 24px 18px 4px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  position: relative;
  z-index: 3;
}

.brand {
  display: flex;
  align-items: center;
  gap: 11px;
}

.brand-icon-wrap {
  width: 42px;
  height: 42px;
  border-radius: 21px;
  background: #ffffff;
  box-shadow: 0 4px 14px rgba(65, 73, 112, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-icon {
  width: 38px;
  height: 38px;
}

.brand-title {
  color: #202433;
  font-size: 20px;
  line-height: 28px;
  font-weight: 800;
}

.icon-button {
  width: 42px;
  height: 42px;
  border-radius: 15px;
  background: #ffffff;
  box-shadow: 0 4px 14px rgba(65, 73, 112, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-icon {
  width: 22px;
  height: 22px;
}

.home-scroll {
  height: 701px;
  padding: 22px 18px 96px;
  box-sizing: border-box;
}

.hero-card,
.recent-card {
  background: #ffffff;
  border-radius: 24px;
  box-shadow: 0 4px 16px rgba(138, 108, 242, 0.08);
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  min-height: 417px;
  padding: 37px 16px 20px;
  margin-bottom: 12px;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  right: -64px;
  top: -77px;
  width: 304px;
  height: 304px;
  border-radius: 152px;
  background: radial-gradient(circle, rgba(161, 138, 245, 0.24) 0%, rgba(161, 138, 245, 0.1) 45%, rgba(255, 255, 255, 0) 74%);
  filter: blur(18px);
}

.hero-top {
  position: relative;
  min-height: 164px;
  z-index: 1;
}

.hero-copy {
  width: 244px;
  position: relative;
  z-index: 2;
}

.hero-title {
  display: block;
  color: #242637;
  font-size: 24px;
  line-height: 34px;
  font-weight: 900;
}

.hero-ai,
.price-highlight {
  color: #8a6cf2;
}

.hero-subtitle {
  margin-top: 17px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 3px;
  color: #888888;
  font-size: 12px;
  line-height: 18px;
  white-space: nowrap;
}

.hero-owl {
  position: absolute;
  right: 2px;
  top: -28px;
  width: 138px;
  height: 138px;
}

.upload-panel {
  position: relative;
  min-height: 194px;
  padding: 43px 22px 42px 160px;
  border-radius: 20px;
  background: #fdfcff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  border: 1px dashed rgba(161, 138, 245, 0.55);
}

.upload-asset {
  position: absolute;
  left: 30px;
  top: 36px;
  width: 116px;
  height: 116px;
}

.upload-copy {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-hint {
  margin-bottom: 12px;
  color: #888888;
  font-size: 14px;
  line-height: 20px;
}

.upload-button {
  width: 137px;
  height: 50px;
  border-radius: 25px;
  background: linear-gradient(90deg, #9c7eff 0%, #7a5cf0 100%);
  box-shadow: 0 4px 12px rgba(138, 108, 242, 0.3);
  color: #ffffff;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
}

.upload-button-icon {
  width: 17px;
  height: 17px;
  filter: brightness(0) invert(1);
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 14px;
}

.quick-card {
  height: 64px;
  padding: 12px 12px 12px 14px;
  border-radius: 20px;
  background: #ffffff;
  box-shadow: 0 4px 16px rgba(138, 108, 242, 0.08);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.quick-icon,
.report-leading {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  margin-right: 11px;
}

.quick-icon image {
  width: 24px;
  height: 24px;
}

.sample-icon {
  background: #f1ebff;
}

.reports-icon {
  background: #eaf4ff;
}

.quick-label {
  flex: 1;
  color: #333333;
  font-size: 15px;
  line-height: 20px;
  font-weight: 700;
}

.quick-chevron,
.more-chevron,
.row-chevron {
  color: #a18af5;
  font-size: 22px;
  line-height: 22px;
  font-weight: 500;
}

.reports-chevron {
  color: #93c5fd;
}

.recent-card {
  min-height: 159px;
  padding: 15px 14px 13px;
  margin-bottom: 18px;
}

.section-head {
  height: 25px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.section-title {
  color: #252938;
  font-size: 17px;
  line-height: 24px;
  font-weight: 900;
}

.more-link {
  display: flex;
  align-items: center;
  gap: 2px;
  color: #888888;
  font-size: 12px;
  line-height: 18px;
}

.more-chevron {
  color: #b8becb;
  font-size: 17px;
}

.report-row {
  height: 47px;
  display: flex;
  align-items: center;
  width: 100%;
}

.report-leading {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  margin-right: 12px;
  border: 1px solid transparent;
  box-sizing: border-box;
}

.report-leading image {
  width: 26px;
  height: 26px;
}

.math-icon {
  background: #eff7ff;
  border-color: #dceeff;
}

.error-icon {
  background: #fff1f5;
  border-color: #ffe1ea;
}

.report-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #333333;
  font-size: 15px;
  line-height: 22px;
  font-weight: 600;
}

.report-status {
  flex: 0 0 auto;
  max-width: 105px;
  height: 24px;
  padding: 0 8px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 12px;
  line-height: 16px;
  white-space: nowrap;
  overflow: hidden;
}

.status-done {
  color: #16a05d;
  background: #edfff5;
}

.status-pending {
  color: #f19a2a;
  background: #fff7ed;
}

.row-chevron {
  margin-left: 6px;
  color: #d1d5db;
  font-size: 18px;
}

.row-divider {
  height: 1px;
  margin-left: 52px;
  background: #f2f3f7;
}

.bottom-tabs {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 75px;
  padding: 7px 48px 10px;
  background: rgba(255, 255, 255, 0.94);
  border-top: 1px solid #f1f2f6;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  z-index: 5;
}

.tab-item {
  width: 72px;
  height: 58px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  color: #9ca3af;
  font-size: 11px;
  line-height: 14px;
  font-weight: 600;
}

.tab-item.active {
  color: #8a6cf2;
}

.tab-icon {
  width: 24px;
  height: 24px;
}

.auth-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 60;
  background: rgba(17, 24, 39, 0.38);
  display: flex;
  align-items: flex-end;
}

.auth-mask.preview-hidden {
  display: none;
}

.auth-mask.preview {
  display: none;
}

.auth-sheet {
  width: 100%;
  padding: 42rpx 36rpx calc(38rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.auth-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.auth-copy {
  display: block;
  margin-top: 18rpx;
  color: #4f5567;
  font-size: 27rpx;
  line-height: 42rpx;
}

.auth-actions {
  margin-top: 34rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.auth-secondary,
.auth-primary {
  height: 86rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 800;
  text-align: center;
}

.auth-secondary {
  color: #4f5567;
  background: #f2f4f7;
}

.auth-primary {
  color: #ffffff;
  background: #7656f3;
}
