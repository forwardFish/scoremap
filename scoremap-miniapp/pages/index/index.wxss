page {
  min-height: 100%;
  background: #f8f9ff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  font: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7ff 0%, #fbfbff 52%, #fff 100%);
  color: #111827;
  box-sizing: border-box;
}

.home-content {
  padding: 0 28rpx 172rpx;
  box-sizing: border-box;
}

.status-space {
  height: 74rpx;
}

.top-bar {
  height: 92rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.brand-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 42%, #9fb2c6 0 14%, transparent 15%),
    radial-gradient(circle at 50% 52%, #d7e2ef 0 22%, transparent 23%),
    linear-gradient(145deg, #111827, #344156);
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.18);
}

.page-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.message-button {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91, 86, 140, 0.12);
  position: relative;
}

.message-button::before {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 18rpx;
  width: 34rpx;
  height: 24rpx;
  border: 4rpx solid #475569;
  border-radius: 12rpx;
}

.message-button::after {
  content: "";
  position: absolute;
  right: 14rpx;
  top: 15rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ef4444;
  box-shadow: 0 0 0 3rpx #fff;
}

.hero-card,
.quick-card,
.recent-card {
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 18rpx 48rpx rgba(87, 79, 154, 0.1);
}

.hero-card {
  margin-top: 2rpx;
  min-height: 682rpx;
  border-radius: 0 0 38rpx 38rpx;
  padding: 42rpx 38rpx 38rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.hero-copy {
  width: 68%;
  position: relative;
  z-index: 2;
}

.hero-title,
.hero-title-line {
  display: block;
  font-size: 44rpx;
  line-height: 1.28;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title-line {
  display: flex;
  flex-wrap: wrap;
}

.hero-accent,
.price {
  color: #8b3cf6;
}

.hero-subtitle {
  display: block;
  margin-top: 26rpx;
  color: #697386;
  font-size: 25rpx;
  line-height: 1.45;
}

.owl-poster {
  position: absolute;
  right: 0;
  top: 0;
  width: 224rpx;
  height: 228rpx;
  background: #171624;
  overflow: hidden;
}

.poster-owl {
  position: absolute;
  left: 28rpx;
  top: 16rpx;
  width: 172rpx;
  height: 188rpx;
  border-radius: 50% 50% 44% 44%;
  background: linear-gradient(160deg, #6b3b18, #e6c48c 48%, #f8ead0 52%, #5f361a);
}

.poster-face {
  position: absolute;
  left: 36rpx;
  top: 48rpx;
  width: 100rpx;
  height: 78rpx;
  border-radius: 50%;
  background: #f9e5bf;
}

.poster-eye {
  position: absolute;
  top: 18rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffcf3a;
  border: 6rpx solid #101827;
  box-sizing: border-box;
}

.poster-eye.left {
  left: 18rpx;
}

.poster-eye.right {
  right: 18rpx;
}

.poster-beak {
  position: absolute;
  left: 41rpx;
  top: 44rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 18rpx solid #f59e0b;
}

.poster-brow {
  position: absolute;
  top: 52rpx;
  width: 58rpx;
  height: 12rpx;
  border-radius: 8rpx;
  background: #23160d;
  z-index: 3;
}

.poster-brow.left {
  left: 34rpx;
  transform: rotate(22deg);
}

.poster-brow.right {
  right: 34rpx;
  transform: rotate(-22deg);
}

.poster-chest {
  position: absolute;
  left: 44rpx;
  bottom: 22rpx;
  width: 84rpx;
  height: 74rpx;
  border-radius: 50%;
  background: #f6ead3;
}

.upload-panel {
  margin-top: 72rpx;
  min-height: 342rpx;
  border: 3rpx dashed #d9caff;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

.folder-art {
  width: 188rpx;
  height: 148rpx;
  position: relative;
  margin-bottom: 30rpx;
}

.folder-back {
  position: absolute;
  left: 28rpx;
  top: 0;
  width: 130rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: linear-gradient(150deg, #1f6472, #0d1f25);
  transform: rotate(-4deg);
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.18);
}

.folder-front {
  position: absolute;
  left: 2rpx;
  bottom: 0;
  width: 184rpx;
  height: 104rpx;
  border-radius: 14rpx 18rpx 18rpx 18rpx;
  background: linear-gradient(145deg, #72d9e4, #143f46);
  box-shadow: 0 16rpx 30rpx rgba(15, 72, 82, 0.22);
}

.folder-front::before {
  content: "";
  position: absolute;
  left: 0;
  top: -22rpx;
  width: 76rpx;
  height: 36rpx;
  border-radius: 14rpx 14rpx 0 0;
  background: #7ce7ef;
}

.upload-hint {
  color: #697386;
  font-size: 30rpx;
  line-height: 1;
}

.primary-button {
  margin-top: 30rpx;
  width: 330rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #9471f6, #765cf5);
  box-shadow: 0 16rpx 28rpx rgba(118, 92, 245, 0.3);
}

.upload-icon {
  font-size: 34rpx;
  line-height: 1;
}

.quick-grid {
  margin-top: 32rpx;
  display: flex;
  gap: 20rpx;
}

.quick-card {
  flex: 1;
  height: 142rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 29rpx;
  font-weight: 800;
}

.sample-card {
  background: linear-gradient(135deg, #fff8ff, #f4ecff);
}

.report-card {
  background: linear-gradient(135deg, #f8fbff, #edf3ff);
}

.quick-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  margin-right: 24rpx;
  position: relative;
}

.sample-icon {
  background: #f0d8ff;
}

.report-icon {
  background: #dbeafe;
}

.quick-icon::before {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 13rpx;
  width: 25rpx;
  height: 30rpx;
  border-radius: 4rpx;
  border: 4rpx solid currentColor;
  color: #7c3aed;
  box-sizing: border-box;
}

.report-icon::before {
  color: #2563eb;
}

.sample-icon::after {
  content: "+";
  position: absolute;
  left: 22rpx;
  top: 13rpx;
  color: #7c3aed;
  font-size: 28rpx;
  font-weight: 800;
}

.chevron {
  margin-left: auto;
  color: #b6abc9;
  font-size: 44rpx;
  font-weight: 400;
}

.report-card .chevron {
  color: #93c5fd;
}

.recent-card {
  margin-top: 36rpx;
  border-radius: 34rpx;
  padding: 42rpx 40rpx 32rpx;
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.more-button {
  color: #9aa3b2;
  font-size: 25rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.report-row {
  min-height: 140rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #edf0f8;
}

.report-row:first-of-type {
  border-top: 0;
}

.report-thumb {
  width: 86rpx;
  height: 86rpx;
  border-radius: 22rpx;
  margin-right: 26rpx;
  position: relative;
  background: #111;
}

.math-thumb::after {
  content: "+";
  position: absolute;
  left: 23rpx;
  top: 10rpx;
  color: #ef4444;
  font-size: 44rpx;
  font-weight: 300;
}

.wrong-thumb {
  background: radial-gradient(circle at 50% 48%, #3f3520 0 8%, #0f172a 36%, #020617 100%);
}

.report-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
}

.status {
  padding: 8rpx 16rpx;
  border-radius: 14rpx;
  font-size: 21rpx;
  white-space: nowrap;
}

.done {
  color: #16a34a;
  background: #ecfdf3;
}

.pending {
  color: #f97316;
  background: #fff7ed;
}

.row-arrow {
  margin-left: 16rpx;
  color: #c7ccd5;
  font-size: 42rpx;
}

.bottom-tabs {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(122rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-radius: 42rpx 42rpx 0 0;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 36rpx rgba(78, 68, 134, 0.1);
  z-index: 20;
}

.bottom-tabs::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: calc(12rpx + env(safe-area-inset-bottom));
  width: 150rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #111827;
  transform: translateX(-50%);
}

.tab-item {
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
  font-weight: 700;
}

.tab-item.active {
  color: #8b3cf6;
}

.tab-icon {
  width: 38rpx;
  height: 38rpx;
  position: relative;
}

.home-icon::before {
  content: "";
  position: absolute;
  left: 2rpx;
  top: 13rpx;
  width: 34rpx;
  height: 24rpx;
  border-radius: 6rpx;
  background: currentColor;
}

.home-icon::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 1rpx;
  width: 28rpx;
  height: 28rpx;
  background: currentColor;
  transform: rotate(45deg);
  border-radius: 5rpx;
}

.my-icon::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 3rpx;
  width: 17rpx;
  height: 17rpx;
  border-radius: 50%;
  background: currentColor;
}

.my-icon::after {
  content: "";
  position: absolute;
  left: 4rpx;
  bottom: 1rpx;
  width: 30rpx;
  height: 18rpx;
  border-radius: 18rpx 18rpx 6rpx 6rpx;
  background: currentColor;
}
