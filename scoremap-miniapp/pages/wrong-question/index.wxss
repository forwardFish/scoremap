@import "../ai-tutor/c13-common.wxss";

.wrong-question-page .content-scroll {
  height: 714px;
}

.question-card {
  margin: 13px 16px 12px;
  padding: 10px 16px 16px;
  border-radius: 5px;
  background: #ffffff;
  box-shadow: 0 6px 20px rgba(82, 69, 135, 0.08);
}

.tag-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.tag {
  height: 19px;
  padding: 0 13px;
  border-radius: 10px;
  background: #f1edff;
  color: #6f55e8;
  font-size: 11px;
  line-height: 19px;
  font-weight: 700;
}

.tag.primary {
  background: #6f55e8;
  color: #ffffff;
}

.tag.danger {
  margin-left: auto;
  background: #ffe7e5;
  color: #d64644;
}

.section {
  position: relative;
  margin-top: 10px;
}

.section-marker {
  position: absolute;
  left: 0;
  top: 2px;
  width: 4px;
  height: 18px;
  border-radius: 3px;
  background: #6f55e8;
}

.section-title {
  display: block;
  padding-left: 12px;
  color: #17213c;
  font-size: 15px;
  line-height: 21px;
  font-weight: 700;
}

.question-text,
.muted,
.answer {
  display: block;
  margin-top: 8px;
  color: #343b55;
  font-size: 13px;
  line-height: 21px;
}

.answer {
  color: #5e43e7;
  font-weight: 700;
}

.answer-paper {
  margin-top: 8px;
  padding: 14px 18px;
  border-radius: 9px;
  background: #f0f0f0;
  color: #555b69;
  font-size: 13px;
  line-height: 22px;
  display: flex;
  flex-direction: column;
}

.two-col {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 12px;
}

.diagnosis-box {
  margin-top: 13px;
  padding: 13px 15px;
  border-radius: 9px;
  background: #f5efff;
  color: #30384e;
  font-size: 13px;
  line-height: 20px;
}

.diagnosis-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  color: #1e2440;
  font-weight: 700;
}

.diagnosis-head image {
  width: 18px;
  height: 18px;
}

.summary-row {
  margin-top: 12px;
  display: grid;
  grid-template-columns: 1fr 112px;
  gap: 8px;
}

.mini-owl {
  width: 112px;
  height: 78px;
  border-radius: 4px;
  background: #332750;
}

.ai-button {
  margin-top: 12px;
  width: 100%;
  height: 48px;
  border-radius: 9px;
  background: #6b4ee6;
  color: #ffffff;
  font-size: 15px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.ai-button image {
  width: 20px;
  height: 20px;
  filter: brightness(0) invert(1);
}

.history-row {
  margin: 0 16px;
  height: 50px;
  border-radius: 8px;
  background: #f5f1fb;
  display: flex;
  align-items: center;
  padding: 0 16px;
  box-sizing: border-box;
  color: #30384e;
  font-size: 13px;
  font-weight: 700;
}

.history-icon {
  width: 28px;
  height: 28px;
  margin-right: 10px;
  border-radius: 14px;
  color: #6f55e8;
  text-align: center;
  line-height: 28px;
  font-size: 18px;
}
