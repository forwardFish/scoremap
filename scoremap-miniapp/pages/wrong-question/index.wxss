page {
  background: #fdf8ff;
  color: #1c1b23;
}

.wq-page {
  min-height: 100vh;
  background: #fdf8ff;
  padding-bottom: 92px;
  font-family: "Plus Jakarta Sans", Arial, sans-serif;
}

.wq-topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  background: #fdf8ff;
  box-shadow: 0 2px 10px rgba(92, 71, 205, 0.06);
}

.wq-title-wrap,
.wq-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.icon-btn {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  background: transparent;
  color: #5a45cb;
  font-size: 13px;
  line-height: 40px;
  font-weight: 700;
  padding: 0;
}

.icon-btn::after,
.bottom-nav button::after,
.history-row::after,
.ai-cta::after {
  border: 0;
}

.wq-title {
  color: #5a45cb;
  font-size: 20px;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.wq-top-meta {
  color: #474554;
  font-size: 14px;
  white-space: nowrap;
}

.wq-scroll {
  height: calc(100vh - 148px);
  padding: 24px 16px 32px;
  box-sizing: border-box;
}

.wq-card {
  background: #ffffff;
  border: 1px solid rgba(201, 196, 214, 0.45);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 15px 15px rgba(90, 69, 203, 0.04);
}

.wq-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: space-between;
  margin-bottom: 24px;
}

.wq-tag {
  min-height: 28px;
  border-radius: 8px;
  padding: 6px 10px;
  box-sizing: border-box;
  font-size: 12px;
  line-height: 16px;
  font-weight: 700;
}

.wq-tag.primary {
  background: #7360e5;
  color: #ffffff;
}

.wq-tag.surface {
  background: #f1ecf8;
  color: #5a45cb;
}

.wq-tag.error {
  background: #ffdad6;
  color: #93000a;
}

.wq-section,
.diagnosis-box {
  margin-bottom: 24px;
}

.section-title {
  border-left: 4px solid #5a45cb;
  padding-left: 8px;
  margin-bottom: 12px;
  color: #1c1b23;
  font-size: 16px;
  line-height: 24px;
  font-weight: 700;
}

.section-body {
  display: block;
  color: #474554;
  font-size: 15px;
  line-height: 22px;
}

.answer-box {
  min-height: 96px;
  border: 1px solid rgba(201, 196, 214, 0.55);
  border-radius: 12px;
  padding: 14px;
  background: #f9f9f9;
  color: #474554;
  font-size: 15px;
  line-height: 22px;
  overflow: hidden;
}

.answer-line {
  height: 10px;
  margin-bottom: 12px;
  border-radius: 999px;
  background: rgba(120, 117, 133, 0.16);
}

.answer-line.short {
  width: 62%;
}

.answer-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.compact {
  min-width: 0;
}

.answer-strong {
  color: #5a45cb;
  font-size: 16px;
  line-height: 24px;
  font-weight: 700;
}

.diagnosis-box {
  border-left: 4px solid #fc9d41;
  border-radius: 16px;
  padding: 16px;
  background: #f7f1fd;
}

.diagnosis-title {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  color: #1c1b23;
  font-size: 16px;
  line-height: 24px;
  font-weight: 700;
}

.diagnosis-icon {
  color: #8f4e00;
  font-size: 13px;
}

.summary-section {
  position: relative;
  padding-right: 86px;
  min-height: 96px;
}

.mascot {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 70px;
  height: 70px;
  border-radius: 22px;
  background: linear-gradient(135deg, #e5deff, #7efba4);
  color: #442bb5;
  font-size: 20px;
  font-weight: 800;
  line-height: 60px;
  text-align: center;
  box-shadow: 0 8px 20px rgba(90, 69, 203, 0.18);
}

.mascot-small {
  display: block;
  margin-top: -18px;
  color: #005228;
  font-size: 10px;
  line-height: 12px;
  font-weight: 700;
}

.ai-cta {
  width: 100%;
  height: 54px;
  border-radius: 16px;
  background: linear-gradient(90deg, #5a45cb, #7360e5);
  color: #ffffff;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow: 0 0 20px rgba(115, 96, 229, 0.3);
}

.ai-cta.locked {
  background: #e5e0ec;
  color: #787585;
  box-shadow: none;
}

.history-row {
  width: 100%;
  min-height: 68px;
  margin-top: 24px;
  padding: 14px 16px;
  border-radius: 16px;
  background: #ebe6f2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
}

.history-title {
  color: #1c1b23;
  font-size: 15px;
  line-height: 22px;
  font-weight: 700;
}

.history-latest,
.locked-copy {
  color: #474554;
  font-size: 13px;
  line-height: 18px;
}

.history-arrow {
  color: #474554;
  font-size: 12px;
  font-weight: 700;
}

.locked-copy,
.toast {
  margin-top: 12px;
  padding: 12px 14px;
  border-radius: 12px;
  background: #ffdcc2;
  color: #6b3900;
}

.toast {
  background: #e5deff;
  color: #442bb5;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 12;
  height: 72px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  align-items: center;
  padding: 8px 16px;
  background: rgba(253, 248, 255, 0.94);
  border-top: 1px solid #c9c4d6;
  box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.04);
}

.bottom-nav button {
  height: 48px;
  border-radius: 16px;
  background: transparent;
  color: #474554;
  font-size: 12px;
  font-weight: 700;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
}

.bottom-nav .active {
  background: #7360e5;
  color: #ffffff;
}

.nav-icon {
  display: block;
  font-size: 13px;
  line-height: 15px;
  font-weight: 800;
}
