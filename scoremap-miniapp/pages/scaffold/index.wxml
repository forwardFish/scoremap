<view class="scaffold-screen">
  <view class="scaffold-header">
    <text class="scaffold-kicker">Local route contract</text>
    <text class="scaffold-title">Scoremap Local Scaffold</text>
    <text class="scaffold-subtitle">Shell-only route validation for the local miniapp, API adapter, and database readback contract. This is not a product pixel reference screen.</text>
  </view>

  <view class="contract-card">
    <image class="contract-icon api" src="/assets/icons/document-blue.png" mode="aspectFit" />
    <view class="contract-copy">
      <text class="contract-title">/api/scaffold/ping</text>
      <text class="contract-desc">Local adapter status endpoint</text>
    </view>
  </view>

  <view class="contract-card">
    <image class="contract-icon db" src="/assets/icons/checklist-purple.png" mode="aspectFit" />
    <view class="contract-copy">
      <text class="contract-title">/api/scaffold/db-readback</text>
      <text class="contract-desc">Local diagnosis_orders mutation and readback</text>
    </view>
  </view>

  <view class="contract-note">
    <text>Scaffold evidence proves route and shell rendering only. It must not be promoted to product pixel PASS.</text>
  </view>

  <button class="scaffold-enter" data-action="home" bindtap="onTap">Enter home</button>
</view>
