page { min-height: 100%; background: #f8f8ff; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; text-align: left; }
button::after { border: 0; }

.scaffold-screen {
  min-height: 100vh;
  padding: 64rpx 30rpx 164rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e6e6fa 0%, #f8f8ff 25%, #f8f8ff 100%);
  color: #111827;
}
.scaffold-header { margin-bottom: 30rpx; }
.scaffold-kicker { display: block; margin-bottom: 12rpx; font-size: 22rpx; line-height: 1; font-weight: 900; color: #7c3aed; text-transform: uppercase; }
.scaffold-title { display: block; font-size: 42rpx; line-height: 1.15; font-weight: 900; }
.scaffold-subtitle { display: block; margin-top: 16rpx; font-size: 24rpx; line-height: 1.55; color: #6b7280; }
.contract-card { min-height: 118rpx; margin-bottom: 22rpx; padding: 26rpx; border-radius: 32rpx; background: #fff; box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.05); display: flex; align-items: center; box-sizing: border-box; }
.contract-icon { width: 74rpx; height: 74rpx; border-radius: 24rpx; margin-right: 22rpx; flex: 0 0 auto; position: relative; }
.contract-icon::before { content: ""; position: absolute; left: 18rpx; right: 18rpx; top: 22rpx; height: 8rpx; border-radius: 8rpx; background: currentColor; box-shadow: 0 18rpx 0 currentColor; }
.contract-icon.api { background: #eff6ff; color: #2563eb; }
.contract-icon.db { background: #ecfdf5; color: #047857; }
.contract-copy { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }
.contract-title { font-size: 28rpx; line-height: 1.3; font-weight: 900; color: #111827; word-break: break-all; }
.contract-desc { font-size: 23rpx; line-height: 1.45; color: #6b7280; }
.contract-note { padding: 26rpx; border-radius: 28rpx; background: #fbfbff; border: 2rpx solid #ede9fe; color: #6b7280; font-size: 24rpx; line-height: 1.55; }
.scaffold-enter { position: fixed; left: 30rpx; right: 30rpx; bottom: 46rpx; height: 92rpx; border-radius: 30rpx; background: #111827; color: #fff; font-size: 30rpx; font-weight: 900; display: flex; align-items: center; justify-content: center; text-align: center; box-shadow: 0 18rpx 34rpx rgba(17, 24, 39, 0.18); }

/* Icon asset replacements */
.contract-icon { display: block; object-fit: contain; padding: 8rpx; box-sizing: border-box; }
.contract-icon::before { content: none; }
