@import "./c13-common.wxss";

.title-stack {
  flex: 1;
  text-align: center;
}

.title-stack .top-title {
  display: block;
}

.subtitle {
  display: block;
  margin-top: -2px;
  color: #6044dc;
  font-size: 11px;
  line-height: 14px;
}

.teacher-card,
.question-card,
.history-row {
  margin: 12px 16px 0;
  border-radius: 16px;
  background: #ffffff;
  box-shadow: 0 6px 18px rgba(82, 69, 135, 0.06);
}

.teacher-card {
  padding: 18px 24px 16px;
}

.teacher-avatar {
  float: left;
  width: 64px;
  height: 64px;
  border-radius: 8px;
  margin-right: 14px;
}

.message-bubble {
  min-height: 86px;
  padding: 15px;
  border-radius: 9px;
  border: 1px solid #e6defa;
  background: #fbf9ff;
  color: #1b2340;
  font-size: 14px;
  line-height: 22px;
  box-sizing: border-box;
}

.action-grid {
  clear: both;
  margin-top: 22px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
}

.action-card {
  min-height: 66px;
  border-radius: 10px;
  background: #f3edf9;
  border: 1px solid #e4d8f1;
  color: #1e2440;
  font-size: 12px;
  line-height: 17px;
  font-weight: 700;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  text-align: center;
}

.action-icon {
  width: 24px;
  height: 24px;
  border-radius: 12px;
  border: 2px solid #6b4ee6;
  color: #6b4ee6;
  line-height: 20px;
  box-sizing: border-box;
  font-size: 16px;
}

.action-icon.warm {
  border-color: #b35b00;
  color: #b35b00;
}

.action-icon.green {
  border-color: #0d9356;
  color: #0d9356;
}

.action-card.wide {
  grid-column: span 2;
  flex-direction: row;
}

.action-card.wide image {
  width: 20px;
  height: 20px;
}

.action-card.understood {
  background: #09914f;
  color: #ffffff;
}

.question-card {
  display: block;
  padding: 18px 24px;
  box-sizing: border-box;
  text-align: left;
}

.card-head {
  display: flex;
  align-items: center;
  color: #1f2540;
  font-size: 15px;
  font-weight: 700;
}

.card-head image {
  width: 20px;
  height: 20px;
  margin-right: 9px;
}

.chip {
  display: inline-flex;
  margin-top: 22px;
  padding: 2px 8px;
  border-radius: 5px;
  background: #fff0d8;
  color: #a45b00;
  font-size: 10px;
  font-weight: 700;
}

.question-title {
  display: block;
  margin-top: 8px;
  color: #1e2440;
  font-size: 14px;
  font-weight: 700;
}

.formula-box {
  margin-top: 12px;
  padding: 18px 22px;
  border-left: 4px solid #6b4ee6;
  border-radius: 12px;
  background: #ffffff;
  box-shadow: 0 4px 18px rgba(82, 69, 135, 0.08);
  color: #30364e;
  font-size: 14px;
  line-height: 22px;
  display: flex;
  flex-direction: column;
}

.formula {
  margin-top: 8px;
  color: #6b4ee6;
  font-weight: 700;
}

.history-row {
  height: 58px;
  padding: 0 24px;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  color: #23283d;
  font-size: 14px;
  font-weight: 700;
}

.history-icon {
  width: 38px;
  height: 30px;
  margin-right: 10px;
  border-radius: 15px;
  background: #eee7fb;
  color: #6b4ee6;
  text-align: center;
  line-height: 30px;
}

.hint {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 91px;
  text-align: center;
  color: #8d94a5;
  font-size: 11px;
}
