page {
  min-height: 100%;
  background: #f8fafc;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  font: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

.failure-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  overflow: hidden;
  background: #f8fafc;
  color: #10203f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  padding: 23px 5px 0;
}

.failure-header {
  height: 45px;
  margin-left: 15px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.back-button {
  width: 26px;
  height: 40px;
  color: #14213f;
  font-size: 36px;
  line-height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-title {
  color: #101946;
  font-size: 22px;
  line-height: 30px;
  font-weight: 900;
}

.failure-card {
  position: relative;
  height: 748px;
  margin-top: 19px;
  padding-top: 72px;
  border-radius: 22px;
  background: linear-gradient(180deg, #ffffff 0%, #ffffff 72%, #fbfaff 100%);
  box-shadow: 0 12px 34px rgba(94, 73, 170, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.illustration {
  position: relative;
  height: 288px;
}

.paper-graphic {
  position: absolute;
  left: 63px;
  top: 72px;
  width: 106px;
  height: 142px;
  border-radius: 14px;
  background: linear-gradient(145deg, #ffffff 0%, #f4f1ff 100%);
  box-shadow: 0 12px 28px rgba(104, 84, 178, 0.11);
  transform: rotate(-1deg);
}

.paper-graphic::after {
  content: "";
  position: absolute;
  right: 0;
  top: 0;
  width: 34px;
  height: 34px;
  border-radius: 0 14px 0 12px;
  background: #e8e2ff;
}

.paper-line {
  position: absolute;
  left: 22px;
  top: 42px;
  width: 47px;
  height: 7px;
  border-radius: 4px;
  background: #ece8ff;
}

.paper-line.long {
  top: 26px;
  width: 62px;
}

.paper-mountain {
  position: absolute;
  left: 23px;
  bottom: 24px;
  width: 58px;
  height: 42px;
  border-radius: 9px;
  background: linear-gradient(145deg, #d8d2ff 0%, #f2f0ff 100%);
  transform: skew(-8deg);
}

.owl-wrap {
  position: absolute;
  right: 59px;
  top: 40px;
  width: 150px;
  height: 178px;
}

.owl {
  width: 150px;
  height: 178px;
}

.sad-mark {
  position: absolute;
  right: 13px;
  top: -7px;
  width: 34px;
  height: 34px;
  border-radius: 17px;
  border: 4px solid #b7a1f3;
  color: #9a82e8;
  box-sizing: border-box;
  text-align: center;
  line-height: 26px;
  font-size: 18px;
  font-weight: 900;
  transform: rotate(18deg);
}

.error-badge {
  position: absolute;
  left: 128px;
  top: 168px;
  width: 59px;
  height: 59px;
  border-radius: 30px;
  background: #ff6b8f;
  box-shadow: 0 10px 22px rgba(255, 107, 143, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-badge image {
  width: 36px;
  height: 36px;
}

.failure-title {
  display: block;
  margin-top: 22px;
  text-align: center;
  color: #10203f;
  font-size: 27px;
  line-height: 38px;
  font-weight: 900;
}

.failure-copy {
  display: block;
  margin-top: 12px;
  text-align: center;
  color: #647086;
  font-size: 14px;
  line-height: 22px;
}

.retry-button,
.reupload-button {
  width: 280px;
  height: 58px;
  margin-left: auto;
  margin-right: auto;
  border-radius: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19px;
  font-weight: 800;
}

.retry-button {
  margin-top: 45px;
  color: #ffffff;
  background: linear-gradient(180deg, #a383ff 0%, #7757f4 100%);
  box-shadow: 0 8px 18px rgba(122, 87, 244, 0.26);
}

.reupload-button {
  margin-top: 19px;
  color: #7b57f4;
  background: #ffffff;
  border: 1px solid #8f73ff;
  box-sizing: border-box;
}

.home-link {
  width: 120px;
  height: 40px;
  margin: 22px auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b57f4;
  font-size: 15px;
  font-weight: 700;
}
