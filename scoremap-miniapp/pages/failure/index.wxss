page {
  min-height: 100%;
  background: #f8fafc;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  font: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

.failure-page {
  position: relative;
  width: 358px;
  margin: 17px auto 0;
  min-height: 844px;
  overflow: hidden;
  background: #f8fafc;
  border: 1px solid #f0f1f5;
  border-radius: 40px 40px 0 0;
  color: #10203f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  padding: 30px 16px 0;
}

.failure-header {
  height: 66px;
  margin-left: 17px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.back-button {
  width: 28px;
  height: 40px;
  color: #14213f;
  font-size: 36px;
  line-height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-title {
  color: #101946;
  font-size: 21px;
  line-height: 30px;
  font-weight: 800;
}

.failure-card {
  position: relative;
  height: 730px;
  margin-top: 10px;
  padding: 34px 22px 0;
  border-radius: 24px;
  background: linear-gradient(180deg, #ffffff 0%, #ffffff 72%, #fbfaff 100%);
  box-shadow: 0 12px 34px rgba(94, 73, 170, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.illustration {
  position: relative;
  height: 390px;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.failure-illustration {
  width: 220px;
  height: 390px;
  border-radius: 7px;
  background: linear-gradient(135deg, #fbfaff 0%, #f5f2ff 100%);
  box-shadow: 0 8px 18px rgba(40, 38, 70, 0.08);
  overflow: hidden;
  box-sizing: border-box;
  transform: translateY(-9px);
}

.mini-header {
  height: 36px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  gap: 7px;
  color: #111827;
  font-size: 8px;
  font-weight: 800;
  box-sizing: border-box;
}

.mini-back {
  font-size: 15px;
  line-height: 15px;
}

.mini-card {
  width: 198px;
  height: 326px;
  margin: 0 auto;
  padding: 30px 10px 0;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 8px 18px rgba(91, 80, 150, 0.08);
  box-sizing: border-box;
}

.mini-art {
  position: relative;
  width: 154px;
  height: 112px;
  margin: 0 auto;
}

.mini-paper {
  position: absolute;
  left: 2px;
  bottom: 11px;
  width: 58px;
  height: 70px;
  border-radius: 5px;
  background: #f7f6ff;
  transform: rotate(-6deg);
  box-shadow: 8px 12px 18px rgba(101, 84, 180, 0.09);
}

.mini-paper view {
  width: 31px;
  height: 4px;
  margin: 16px 0 0 14px;
  border-radius: 4px;
  background: #e1ddfb;
}

.mini-paper view:nth-child(2) {
  width: 38px;
  margin-top: 13px;
}

.mini-paper view:nth-child(3) {
  width: 28px;
  height: 18px;
  margin-top: 12px;
  border-radius: 3px;
}

.mini-owl {
  position: absolute;
  right: 4px;
  bottom: 0;
  width: 104px;
  height: 104px;
}

.mini-error {
  position: absolute;
  left: 53px;
  bottom: 12px;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #ff6b84;
  color: #ffffff;
  text-align: center;
  font-size: 25px;
  line-height: 27px;
  font-weight: 900;
  box-shadow: 0 6px 12px rgba(255, 107, 132, 0.22);
}

.mini-title {
  display: block;
  margin-top: 21px;
  text-align: center;
  color: #10203f;
  font-size: 14px;
  line-height: 19px;
  font-weight: 900;
}

.mini-copy {
  display: block;
  width: 150px;
  margin: 8px auto 0;
  text-align: center;
  color: #697386;
  font-size: 6px;
  line-height: 10px;
}

.mini-primary,
.mini-secondary {
  width: 158px;
  height: 28px;
  margin: 20px auto 0;
  border-radius: 7px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 8px;
  font-weight: 800;
  box-sizing: border-box;
}

.mini-primary {
  color: #ffffff;
  background: linear-gradient(180deg, #a383ff 0%, #7757f4 100%);
  box-shadow: 0 5px 10px rgba(122, 87, 244, 0.2);
}

.mini-secondary {
  margin-top: 8px;
  color: #7b57f4;
  background: #ffffff;
  border: 1px solid #9a80ff;
}

.mini-home {
  display: block;
  margin-top: 15px;
  color: #7b57f4;
  text-align: center;
  font-size: 6px;
  font-weight: 700;
}

.failure-title {
  display: block;
  margin-top: 10px;
  text-align: center;
  color: #10203f;
  font-size: 26px;
  line-height: 36px;
  font-weight: 900;
}

.failure-copy {
  display: block;
  width: 244px;
  margin: 12px auto 0;
  text-align: center;
  color: #647086;
  font-size: 14px;
  line-height: 22px;
}

.retry-button,
.reupload-button {
  width: 280px;
  height: 58px;
  margin-left: auto;
  margin-right: auto;
  border-radius: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19px;
  font-weight: 800;
}

.retry-button {
  margin-top: 58px;
  color: #ffffff;
  background: linear-gradient(180deg, #a383ff 0%, #7757f4 100%);
  box-shadow: 0 8px 18px rgba(122, 87, 244, 0.26);
}

.reupload-button {
  margin-top: 19px;
  color: #7b57f4;
  background: #ffffff;
  border: 1px solid #8f73ff;
  box-sizing: border-box;
}

.home-link {
  width: 120px;
  height: 40px;
  margin: 22px auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b57f4;
  font-size: 15px;
  font-weight: 700;
}
