page {
  min-height: 100%;
  background: #f8fafc;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  font: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

.failure-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  margin: 0 auto;
  overflow: hidden;
  background: #f8fafc;
  color: #10203f;
  font-family: "Inter", "Microsoft YaHei UI", "Microsoft YaHei", "PingFang SC", "Noto Sans SC", "DengXian", "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, "Helvetica Neue", Arial, sans-serif;
  box-sizing: border-box;
  padding: 22px 20px 0;
}

.failure-header {
  height: 52px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.back-button {
  width: 28px;
  height: 40px;
  color: #14213f;
  font-size: 34px;
  line-height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-title {
  color: #101946;
  font-size: 22px;
  line-height: 30px;
  font-weight: 700;
}

.failure-card {
  position: relative;
  min-height: 710px;
  margin-top: 8px;
  padding: 30px 20px 0;
  border-radius: 24px;
  background: linear-gradient(180deg, #ffffff 0%, #ffffff 72%, #fbfaff 100%);
  box-shadow: 0 12px 34px rgba(94, 73, 170, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.illustration {
  position: relative;
  width: 222px;
  height: 310px;
  margin: 0 auto;
}

.paper-ghost {
  position: absolute;
  left: -8px;
  bottom: 34px;
  width: 132px;
  height: 162px;
  border-radius: 10px;
  background: #f7f6ff;
  transform: rotate(-7deg);
  box-shadow: 12px 18px 26px rgba(101, 84, 180, 0.1);
}

.paper-ghost view {
  width: 46px;
  height: 7px;
  margin: 24px 0 0 20px;
  border-radius: 7px;
  background: #e1ddfb;
}

.paper-ghost view:nth-child(2) {
  width: 58px;
  margin-top: 18px;
}

.paper-ghost view:nth-child(3) {
  width: 42px;
  height: 24px;
  margin-top: 18px;
  border-radius: 6px;
}

.failure-owl {
  position: absolute;
  right: -22px;
  bottom: 18px;
  width: 232px;
  height: 232px;
}

.error-badge {
  position: absolute;
  left: 62px;
  bottom: 34px;
  width: 62px;
  height: 62px;
  border-radius: 50%;
  background: #ff6b84;
  color: #ffffff;
  text-align: center;
  font-size: 52px;
  line-height: 56px;
  font-weight: 700;
  box-shadow: 0 8px 16px rgba(255, 107, 132, 0.22);
}

.spark {
  position: absolute;
  color: #d5ccff;
  font-size: 24px;
  font-weight: 700;
}

.spark-one {
  left: 78px;
  top: 106px;
}

.spark-two {
  right: 0;
  top: 130px;
}

.failure-title {
  display: block;
  margin-top: 18px;
  text-align: center;
  color: #10203f;
  font-size: 28px;
  line-height: 38px;
  font-weight: 700;
}

.failure-copy {
  display: block;
  width: 270px;
  margin: 14px auto 0;
  text-align: center;
  color: #4f5b70;
  font-size: 15px;
  line-height: 24px;
  font-weight: 500;
}

.retry-button,
.reupload-button {
  width: 310px;
  height: 58px;
  margin-left: auto;
  margin-right: auto;
  border-radius: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19px;
  font-weight: 700;
}

.retry-button {
  margin-top: 40px;
  color: #ffffff;
  background: linear-gradient(180deg, #a383ff 0%, #7757f4 100%);
  box-shadow: 0 8px 18px rgba(122, 87, 244, 0.26);
}

.reupload-button {
  margin-top: 18px;
  color: #7b57f4;
  background: #ffffff;
  border: 1px solid #8f73ff;
  box-sizing: border-box;
}

.home-link {
  width: 140px;
  height: 40px;
  margin: 18px auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7048f0;
  font-size: 15px;
  font-weight: 700;
}
