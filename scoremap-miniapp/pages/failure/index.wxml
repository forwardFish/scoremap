<view class="failure-page">
  <view class="failure-header">
    <button class="back-button" data-action="home" bindtap="onTap" aria-label="返回">
      <text>‹</text>
    </button>
    <text class="page-title">处理失败</text>
  </view>

  <view class="failure-card">
    <view class="illustration">
      <view class="paper-ghost">
        <view></view>
        <view></view>
        <view></view>
      </view>
      <image class="failure-owl" src="/assets/icons/analysis-owl.png" mode="aspectFit" />
      <view class="error-badge">×</view>
      <text class="spark spark-one">•</text>
      <text class="spark spark-two">✦</text>
    </view>

    <text class="failure-title">分析没有成功</text>
    <text class="failure-copy">可能是资料不清晰或网络异常，请稍后重试。</text>

    <button class="retry-button" data-action="retry" bindtap="onTap">重新开始分析</button>
    <button class="reupload-button" data-action="reupload" bindtap="onTap">重新上传资料</button>
    <button class="home-link" data-action="home" bindtap="onTap">返回首页 ›</button>
  </view>
</view>
