page { min-height: 100%; background: #f8f9fe; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; }
button::after { border: 0; }

.unlock-screen {
  min-height: 100vh;
  padding-bottom: 356rpx;
  box-sizing: border-box;
  background: #f8f9fe;
  color: #111827;
  position: relative;
  overflow: hidden;
}

.unlock-decor {
  position: absolute;
  color: #7b61ff;
  opacity: 0.28;
  font-size: 30rpx;
}

.star-a { left: 76rpx; top: 154rpx; color: #ffc107; opacity: 0.58; }
.star-b { right: 80rpx; top: 274rpx; }
.star-c { left: 246rpx; top: 602rpx; }

.unlock-header {
  height: 112rpx;
  padding: 18rpx 36rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(248, 249, 254, 0.92);
}

.unlock-back {
  width: 64rpx;
  height: 64rpx;
  position: relative;
}

.unlock-back::before {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 15rpx;
  width: 26rpx;
  height: 26rpx;
  border-left: 7rpx solid #111827;
  border-bottom: 7rpx solid #111827;
  border-radius: 3rpx;
  transform: rotate(45deg);
}

.unlock-title {
  font-size: 34rpx;
  font-weight: 900;
}

.unlock-header-spacer { width: 64rpx; height: 64rpx; }
.unlock-main { padding: 18rpx 30rpx 0; box-sizing: border-box; }

.unlock-summary-card {
  min-height: 378rpx;
  border-radius: 44rpx;
  background: #fff;
  box-shadow: 0 18rpx 50rpx rgba(123, 97, 255, 0.08);
  padding: 44rpx 36rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.unlock-tag,
.unlock-ready {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  font-weight: 900;
}

.unlock-tag {
  height: 44rpx;
  padding: 0 22rpx;
  background: #ebf0ff;
  color: #7b61ff;
  font-size: 24rpx;
  gap: 10rpx;
  margin-bottom: 34rpx;
}

.tag-icon {
  width: 24rpx;
  height: 28rpx;
  border-radius: 6rpx;
  background: #7b61ff;
  position: relative;
}

.tag-icon::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 7rpx;
  width: 8rpx;
  height: 12rpx;
  border-right: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(45deg);
}

.unlock-report-title {
  display: block;
  width: 66%;
  color: #111827;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 900;
  margin-bottom: 22rpx;
}

.unlock-summary {
  display: block;
  width: 66%;
  color: #667085;
  font-size: 30rpx;
  line-height: 1.55;
  margin-bottom: 34rpx;
}

.unlock-ready {
  height: 54rpx;
  padding: 0 22rpx;
  background: #e6f6ec;
  color: #4caf50;
  font-size: 26rpx;
  gap: 10rpx;
}

.ready-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #4caf50;
  position: relative;
}

.ready-check::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 5rpx;
  width: 9rpx;
  height: 14rpx;
  border-right: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
}

.unlock-mascot {
  position: absolute;
  right: -12rpx;
  bottom: 0;
  width: 218rpx;
  height: 218rpx;
  background: #a46538;
  overflow: hidden;
}

.mascot-head {
  position: absolute;
  left: 47rpx;
  top: 32rpx;
  width: 124rpx;
  height: 132rpx;
  border-radius: 48% 48% 42% 42%;
  background: linear-gradient(160deg, #ffd083, #8c5a35);
  box-shadow: inset 0 -18rpx 0 rgba(72, 41, 28, 0.35);
}

.mascot-eye {
  position: absolute;
  top: 90rpx;
  width: 16rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #111827;
  z-index: 2;
}
.mascot-eye.left { left: 84rpx; }
.mascot-eye.right { right: 78rpx; }
.mascot-beard {
  position: absolute;
  left: 73rpx;
  bottom: 30rpx;
  width: 76rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #4c3329;
}

.unlock-section-title {
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #d1c4ff;
  font-size: 28rpx;
}

.section-copy {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.unlock-feature-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.feature-card {
  min-height: 306rpx;
  border-radius: 34rpx;
  background: #fff;
  padding: 48rpx 24rpx 26rpx;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 16rpx 46rpx rgba(31, 41, 55, 0.04);
}

.lock-badge {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #f0eeff;
}

.lock-badge::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 17rpx;
  width: 18rpx;
  height: 15rpx;
  border: 5rpx solid #7b61ff;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.lock-badge::after {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 9rpx;
  width: 12rpx;
  height: 12rpx;
  border: 5rpx solid #7b61ff;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
  box-sizing: border-box;
}

.feature-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  margin-bottom: 28rpx;
  border: 18rpx solid #f0eeff;
  box-sizing: border-box;
  background: radial-gradient(circle at 40% 38%, #ffffff 0 8%, #111827 10% 58%, #020617 60%);
}

.feature-icon.teal { border-color: #e6f6ec; background: radial-gradient(circle at 45% 38%, #9ffcf1 0 8%, #054f54 12% 58%, #022c2d 60%); }
.feature-icon.gold { border-color: #ebf4ff; background: radial-gradient(circle at 50% 44%, #ffd166 0 8%, #9a5a10 12% 58%, #120805 60%); }
.feature-icon.amber { border-color: #fff3e0; background: radial-gradient(circle at 50% 44%, #fff4b8 0 8%, #a16207 12% 58%, #111827 60%); }

.feature-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.feature-desc {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.3;
  min-height: 62rpx;
}

.skeleton {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.skeleton view {
  height: 8rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
}
.skeleton view:first-child { width: 58rpx; }
.skeleton view:last-child { width: 28rpx; }

.unlock-pay-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  border-radius: 34rpx 34rpx 0 0;
  background: #fff;
  padding: 42rpx 36rpx 34rpx;
  box-sizing: border-box;
  box-shadow: 0 -10rpx 40rpx rgba(31, 41, 55, 0.08);
}

.unlock-price-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 10rpx;
  color: #7b61ff;
}

.unlock-price {
  font-size: 76rpx;
  line-height: 1;
  font-weight: 900;
}

.unlock-unit {
  font-size: 28rpx;
  font-weight: 900;
}

.unlock-origin {
  color: #9ca3af;
  font-size: 25rpx;
  text-decoration: line-through;
}

.unlock-assurance {
  margin: 22rpx 0 34rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  color: #667085;
  font-size: 25rpx;
  font-weight: 700;
}

.shield {
  width: 26rpx;
  height: 30rpx;
  background: #7b61ff;
  clip-path: polygon(50% 0, 92% 16%, 82% 72%, 50% 100%, 18% 72%, 8% 16%);
}

.unlock-pay {
  height: 104rpx;
  width: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #8a71ff 0%, #6344ff 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(123, 97, 255, 0.26);
}

.unlock-cancel {
  width: 100%;
  margin-top: 24rpx;
  color: #9ca3af;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}
