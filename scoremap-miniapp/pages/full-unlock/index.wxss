page {
  min-height: 100%;
  background: #f8f8ff;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.unlock-page {
  position: relative;
  width: 390px;
  min-height: 844px;
  overflow: hidden;
  background: linear-gradient(180deg, #fbfbff 0%, #f8f7ff 100%);
  color: #151b3a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.status-bar {
  height: 34px;
  padding: 8px 34px 0;
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
  color: #050816;
  font-size: 12px;
  font-weight: 700;
}

.status-bar text:last-child,
.status-bar span:last-child {
  position: relative;
  width: 38px;
  height: 13px;
  color: transparent;
}

.status-bar text:last-child::before,
.status-bar span:last-child::before {
  content: "";
  position: absolute;
  right: 15px;
  bottom: 2px;
  width: 15px;
  height: 10px;
  background:
    linear-gradient(#111 0 0) left 7px bottom / 2px 3px no-repeat,
    linear-gradient(#111 0 0) left 11px bottom / 2px 5px no-repeat,
    linear-gradient(#111 0 0) left 15px bottom / 2px 7px no-repeat;
}

.status-bar text:last-child::after,
.status-bar span:last-child::after {
  content: "";
  position: absolute;
  right: 0;
  bottom: 1px;
  width: 13px;
  height: 8px;
  border: 1px solid #111;
  border-radius: 2px;
  box-shadow: 3px 2px 0 -1px #111;
  background: linear-gradient(90deg, #111 0 9px, transparent 9px);
}

.top-bar {
  position: relative;
  height: 50px;
  padding: 0 45px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.back-nav {
  position: absolute;
  left: 50px;
  top: 6px;
  width: 24px;
  height: 32px;
  color: #111827;
  font-size: 34px;
  line-height: 28px;
}

.page-title {
  color: #111827;
  font-size: 17px;
  font-weight: 900;
}

.page-subtitle {
  position: absolute;
  right: 48px;
  top: 16px;
  color: #1d2450;
  font-size: 10px;
}

.dimmed-content {
  padding: 0 45px;
  filter: blur(0.3px);
  opacity: 0.42;
}

.hero-card,
.summary-card {
  width: 300px;
  border-radius: 9px;
  background: #ffffff;
  box-shadow: 0 7px 22px rgba(108, 91, 190, 0.1);
  box-sizing: border-box;
}

.hero-card {
  height: 145px;
  padding: 22px 14px 14px 18px;
  display: flex;
  justify-content: space-between;
  background: linear-gradient(135deg, #f8f6ff 0%, #f2efff 100%);
}

.hero-owl {
  width: 104px;
  height: 110px;
  margin-top: -8px;
}

.hero-title,
.hero-copy,
.success-pill {
  display: block;
}

.hero-title {
  width: 168px;
  color: #172047;
  font-size: 20px;
  font-weight: 900;
  line-height: 24px;
}

.hero-copy {
  width: 168px;
  margin-top: 9px;
  color: #2d365d;
  font-size: 11px;
  line-height: 18px;
}

.success-pill {
  width: 84px;
  height: 21px;
  margin-top: 13px;
  border-radius: 7px;
  background: #dcfce7;
  color: #059669;
  font-size: 10px;
  line-height: 21px;
  text-align: center;
}

.summary-card {
  margin-top: 13px;
  padding: 0 14px;
}

.summary-card view {
  height: 40px;
  display: grid;
  grid-template-columns: 28px 92px 1fr;
  align-items: center;
  border-bottom: 1px solid #edeafa;
  color: #111827;
  font-size: 11px;
}

.summary-card view text:first-child {
  width: 23px;
  height: 23px;
  border-radius: 7px;
  color: #7458ff;
  background: #f0ecff;
  font-size: 13px;
  line-height: 23px;
  text-align: center;
  font-weight: 900;
}

.summary-card view text:nth-child(2) {
  font-weight: 900;
}

.summary-card view text:nth-child(3) {
  color: #253056;
  font-size: 10px;
  text-align: right;
}

.sheet-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: flex-end;
}

.modal-card {
  position: relative;
  width: 390px;
  min-height: 462px;
  padding: 43px 46px 32px;
  border-radius: 34px 34px 0 0;
  background: linear-gradient(180deg, #ffffff 0%, #fbfbff 100%);
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 -12px 40px rgba(99, 83, 176, 0.18);
}

.sheet-handle {
  position: absolute;
  top: 15px;
  left: 181px;
  width: 28px;
  height: 5px;
  border-radius: 5px;
  background: #d8d8ee;
}

.close-button {
  position: absolute;
  right: 31px;
  top: 19px;
  width: 30px;
  height: 30px;
  border-radius: 15px;
  background: #f3f1ff;
  color: #827a9f;
  font-size: 24px;
  line-height: 26px;
}

.title,
.copy {
  display: block;
}

.title {
  color: #121a43;
  font-size: 22px;
  line-height: 28px;
  font-weight: 900;
}

.price {
  margin-top: 18px;
  color: #7052ff;
  font-weight: 900;
}

.price text:first-child {
  font-size: 52px;
  line-height: 52px;
}

.price text:last-child {
  margin-left: 4px;
  font-size: 18px;
}

.copy {
  margin-top: 11px;
  color: #7d84a3;
  font-size: 12px;
}

.benefit-panel {
  margin-top: 21px;
  padding: 15px 18px 13px;
  border-radius: 8px;
  border: 1px solid #ebe6ff;
  background: linear-gradient(180deg, #f8f6ff 0%, #ffffff 100%);
  box-sizing: border-box;
}

.benefit-title {
  display: block;
  color: #654cff;
  font-size: 14px;
  font-weight: 900;
}

.benefit-grid {
  margin-top: 13px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  row-gap: 12px;
  column-gap: 22px;
  text-align: left;
}

.benefit-grid text {
  color: #23305a;
  font-size: 12px;
}

.benefit-grid text::before {
  content: "✓";
  margin-right: 6px;
  color: #654cff;
}

.pay-button {
  width: 298px;
  height: 50px;
  margin: 14px auto 0;
  border-radius: 9px;
  background: linear-gradient(180deg, #805cff 0%, #5b3df4 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 900;
  box-shadow: 0 8px 18px rgba(91, 61, 244, 0.22);
}

.cancel-button {
  width: 298px;
  height: 28px;
  margin: 12px auto 0;
  color: #654cff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 800;
}
