<view class="unlock-page">
  <view class="status-bar">
    <text>9:41</text>
    <text>wifi</text>
  </view>

  <view class="top-bar">
    <button class="back-nav" data-action="back" bindtap="onTap">‹</button>
    <text class="page-title">初步分析报告</text>
    <text class="page-subtitle">初一数学月考分析</text>
  </view>

  <view class="dimmed-content">
    <view class="hero-card">
      <view>
        <text class="hero-title">初步分析已生成</text>
        <text class="hero-copy">整体基础较好，计算粗心和几何证明是本次失分的主要原因。</text>
        <view class="success-pill">✓ 初步分析已生成</view>
      </view>
      <image class="hero-owl" src="/assets/clean-icons/owl-report-teacher.png" mode="aspectFit" />
    </view>
    <view class="summary-card">
      <view><text>◎</text><text>主要丢分点</text><text>计算失误、几何证明</text></view>
      <view><text>↗</text><text>优先补弱点</text><text>优先提升几何证明能力</text></view>
      <view><text>▣</text><text>答题质量概览</text><text>基础较稳，步骤规范性一般</text></view>
      <view><text>✦</text><text>简短建议</text><text>先修复高频错因，再看完整建议</text></view>
    </view>
  </view>

  <view class="sheet-mask">
    <view class="modal-card">
      <view class="sheet-handle"></view>
      <button class="close-button" data-action="back" bindtap="onTap">×</button>
      <text class="title">确认解锁完整报告</text>
      <view class="price"><text>9.9</text><text>元</text></view>
      <text class="copy">已完成初判，可立即解锁完整提分报告</text>
      <view class="benefit-panel">
        <view class="benefit-title"><text>✦</text><text>支付后可解锁</text><text>✦</text></view>
        <view class="benefit-grid">
          <text>✓ 完整报告</text>
          <text>✓ 7天行动建议</text>
          <text>✓ 详细丢分点分析</text>
          <text>✓ 关键错题修复</text>
          <text>✓ 优先补弱顺序</text>
          <text>✓ 家长学习建议</text>
        </view>
      </view>
      <button class="pay-button" data-action="pay" bindtap="onTap">确认支付 9.9元</button>
      <button class="cancel-button" data-action="back" bindtap="onTap">暂不解锁</button>
    </view>
  </view>
</view>
