page { min-height: 100%; background: #f8f8ff; }
button { margin: 0; padding: 0; border: 0; background: transparent; font: inherit; color: inherit; text-align: left; }
button::after { border: 0; }

.reports-screen {
  min-height: 100vh;
  padding: 48rpx 30rpx 178rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e6e6fa 0%, #f8f8ff 25%, #f8f8ff 100%);
  color: #111827;
}
.reports-header { height: 88rpx; display: flex; align-items: center; justify-content: space-between; }
.header-spacer { width: 148rpx; }
.reports-title { flex: 1; text-align: center; font-size: 36rpx; font-weight: 900; line-height: 1; }
.header-capsule { width: 148rpx; height: 58rpx; border-radius: 999rpx; background: #fff; display: flex; align-items: center; justify-content: space-around; padding: 0 18rpx; box-sizing: border-box; box-shadow: 0 6rpx 14rpx rgba(31, 41, 55, 0.08); }
.capsule-dot { width: 32rpx; height: 32rpx; }
.capsule-divider { width: 2rpx; height: 30rpx; background: #e5e7eb; }
.capsule-target { width: 26rpx; height: 26rpx; border-radius: 50%; box-sizing: border-box; }
.reports-tabs { display: flex; gap: 14rpx; margin: 26rpx 0 26rpx; }
.reports-tab { height: 54rpx; padding: 0 22rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: #fff; color: #6b7280; font-size: 24rpx; font-weight: 700; box-shadow: 0 8rpx 18rpx rgba(31, 41, 55, 0.04); }
.reports-tab.active { background: #111827; color: #fff; }
.report-card { width: 100%; margin-bottom: 22rpx; padding: 28rpx; border-radius: 34rpx; background: #fff; box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.05); box-sizing: border-box; }
.report-card.primary { border: 2rpx solid #ede9fe; }
.report-card.muted { background: #fbfbff; }
.report-card-top { display: flex; align-items: center; min-width: 0; }
.report-icon { width: 78rpx; height: 78rpx; border-radius: 24rpx; margin-right: 22rpx; flex: 0 0 auto; position: relative; }
.report-icon::before { content: ""; position: absolute; left: 20rpx; right: 20rpx; top: 18rpx; height: 8rpx; border-radius: 8rpx; background: currentColor; box-shadow: 0 18rpx 0 currentColor, 0 36rpx 0 currentColor; }
.report-icon.purple { background: #f0edff; color: #7c3aed; }
.report-icon.blue { background: #eff6ff; color: #2563eb; }
.report-icon.orange { background: #fff7ed; color: #f59e0b; }
.report-copy { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }
.report-title { font-size: 30rpx; line-height: 1.25; font-weight: 900; color: #111827; }
.report-meta, .quota-text, .muted-note { font-size: 24rpx; line-height: 1.45; color: #6b7280; }
.report-arrow { width: 32rpx; height: 32rpx; margin-left: 16rpx; }
.report-status-row { margin-top: 24rpx; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.status-pill { min-height: 42rpx; padding: 0 18rpx; border-radius: 999rpx; display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; font-weight: 800; }
.status-icon { width: 24rpx; height: 24rpx; }
.status-pill.success { background: #ecfdf5; color: #047857; }
.status-pill.pending { background: #eff6ff; color: #2563eb; }
.progress-track { height: 10rpx; margin-top: 24rpx; border-radius: 999rpx; overflow: hidden; background: #e5e7eb; }
.progress-fill { width: 45%; height: 100%; border-radius: 999rpx; background: #2563eb; }
.muted-note { display: block; margin-top: 22rpx; }
.reports-bottom-tabs { position: fixed; left: 0; right: 0; bottom: 0; height: 124rpx; padding-bottom: 18rpx; display: flex; background: rgba(255, 255, 255, 0.96); box-shadow: 0 -12rpx 28rpx rgba(31, 41, 55, 0.06); }
.bottom-tab { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; color: #6b7280; font-size: 24rpx; font-weight: 700; text-align: center; }
.bottom-tab.active { color: #2563eb; }
.bottom-tab-icon { width: 34rpx; height: 34rpx; }

/* Icon asset replacements */
.capsule-dot, .capsule-target, .report-icon, .report-arrow, .status-icon, .bottom-tab-icon { display: block; object-fit: contain; }
.report-icon { padding: 8rpx; box-sizing: border-box; }
.report-icon::before { content: none; }
